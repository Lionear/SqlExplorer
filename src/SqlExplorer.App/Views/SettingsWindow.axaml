<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:SqlExplorer.App.Converters"
        xmlns:ctl="using:SqlExplorer.App.Controls"
        xmlns:settings="using:SqlExplorer.Core.Settings"
        x:Class="SqlExplorer.App.Views.SettingsWindow"
        Title="{Binding Loc[Preferences]}"
        Width="800" Height="540" MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <!-- One row per PluginSettingField (Route A) — same shape/look as the connection dialog's fields. -->
    <DataTemplate x:Key="PluginFieldTemplate">
      <StackPanel Spacing="2" Margin="0,4,0,0">
        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource SETextSecondaryBrush}" FontSize="11.5" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Text="{Binding Value}" PlaceholderText="{Binding Watermark}"
                   IsVisible="{Binding IsText}" />
          <ToggleSwitch Grid.Column="0" IsChecked="{Binding BoolValue}" IsVisible="{Binding IsBool}"
                        OnContent="" OffContent="" HorizontalAlignment="Left" />
          <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" ItemsSource="{Binding Choices}"
                    SelectedItem="{Binding Value}" IsVisible="{Binding IsChoice}" />
          <Button Grid.Column="1" Margin="6,0,0,0"
                  Content="{Binding $parent[Window].DataContext.Loc[Browse]}"
                  IsVisible="{Binding HasBrowse}" Click="OnBrowseClick" />
        </Grid>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <!-- Capture chip: accent while listening for keys, red outline while it clashes with another binding. -->
    <Style Selector="ctl|ShortcutCaptureBox:capturing">
      <Setter Property="BorderBrush" Value="{DynamicResource SEAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource SEAccentBrush}" />
      <Setter Property="Background" Value="#223574F0" />
    </Style>
    <Style Selector="ctl|ShortcutCaptureBox.conflict">
      <Setter Property="BorderBrush" Value="{DynamicResource SEStatusErrorBrush}" />
    </Style>
    <!-- Mirrors the Plugin Store's Card look — used by the Plugin sources pane so its rows read the
         same as they did before the Sources tab moved here (SE-122). -->
    <Style Selector="Border.Card">
      <Setter Property="Background" Value="{DynamicResource SEPanelBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SEHairlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="172,*">

    <!-- ============ Category rail ============ -->
    <Border Grid.Column="0" Background="{DynamicResource SEPanelBgBrush}"
            BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*">
        <!-- Search box (SE-161): filters the categories below by label or keyword. -->
        <TextBox Grid.Row="0" Margin="8,8,8,4" PlaceholderText="{Binding Loc[SettingsSearch]}"
                 Text="{Binding SettingsSearch}" />
        <ListBox Grid.Row="1" Background="Transparent" Padding="0,4"
                 ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Data="{Binding Icon}"
                      Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.3"
                      StrokeJoin="Round" StrokeLineCap="Round" />
                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <!-- ============ Content ============ -->
    <Grid Grid.Column="1" RowDefinitions="*,Auto">
      <Panel Grid.Row="0" Margin="24,20">

        <!-- General (scrollable: the Updates cards can push it past the window height) -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=General}">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding Loc[SettingsGeneralCat]}" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Loc[SettingsGeneral]}" FontSize="12" Foreground="{DynamicResource SETextSecondaryBrush}" />
          <TextBlock Text="{Binding Loc[Language]}" FontWeight="SemiBold" Margin="0,6,0,0" />
          <ComboBox Width="200" HorizontalAlignment="Left"
                    ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Text="{Binding Loc[Startup]}" FontWeight="SemiBold" Margin="0,10,0,0" />
          <ToggleSwitch IsChecked="{Binding RestoreTabsOnStartup}"
                        OnContent="{Binding Loc[RestoreTabsOnStartup]}" OffContent="{Binding Loc[RestoreTabsOnStartup]}" />
          <ToggleSwitch IsChecked="{Binding PromptSaveQueryOnClose}"
                        OnContent="{Binding Loc[PromptSaveQueryOnClose]}" OffContent="{Binding Loc[PromptSaveQueryOnClose]}" />
          <ToggleSwitch IsChecked="{Binding ConfirmOnExit}"
                        OnContent="{Binding Loc[ConfirmOnExit]}" OffContent="{Binding Loc[ConfirmOnExit]}" />
          <ToggleSwitch IsChecked="{Binding CloseToTray}"
                        OnContent="{Binding Loc[CloseToTray]}" OffContent="{Binding Loc[CloseToTray]}" />
          <TextBlock Text="{Binding Loc[CloseToTrayHint]}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextFaintBrush}" Margin="24,0,0,0" />
          <TextBlock Text="{Binding Loc[SettingsSchemaTree]}" FontWeight="SemiBold" Margin="0,10,0,0" />
          <ToggleSwitch IsChecked="{Binding ShowSystemDatabases}"
                        OnContent="{Binding Loc[ShowSystemDatabases]}" OffContent="{Binding Loc[ShowSystemDatabases]}" />

          <TextBlock Text="{Binding Loc[SettingsUpdates]}" FontWeight="SemiBold" FontSize="14" Margin="0,14,0,0" />
          <TextBlock Text="{Binding Loc[SettingsUpdatesHint]}" FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextSecondaryBrush}" Margin="0,0,0,4" />

          <!-- Channel selector as radio-cards (SE-137 mockup) -->
          <ListBox ItemsSource="{Binding UpdateChannels}" SelectedItem="{Binding SelectedUpdateChannelOption}"
                   Background="Transparent" BorderThickness="0" Padding="0" MaxWidth="620" HorizontalAlignment="Stretch"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Background" Value="Transparent" />
              </Style>
              <Style Selector="ListBoxItem Border.channelCard">
                <Setter Property="Background" Value="{DynamicResource SEPanelBgBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource SEHairlineBrush}" />
              </Style>
              <Style Selector="ListBoxItem:selected Border.channelCard">
                <Setter Property="BorderBrush" Value="{DynamicResource SEAccentBrush}" />
                <Setter Property="Background" Value="#243B82F6" />
              </Style>
              <!-- Default hidden via a style (not a local value, which a style setter can't override). -->
              <Style Selector="ListBoxItem Ellipse.radioDot">
                <Setter Property="IsVisible" Value="False" />
              </Style>
              <Style Selector="ListBoxItem:selected Ellipse.radioDot">
                <Setter Property="IsVisible" Value="True" />
              </Style>
              <Style Selector="ListBoxItem:selected Ellipse.radioRing">
                <Setter Property="Stroke" Value="{DynamicResource SEAccentBrush}" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Classes="channelCard" BorderThickness="1" CornerRadius="6" Padding="14,11">
                  <Grid ColumnDefinitions="Auto,Auto,*">
                    <!-- radio indicator -->
                    <Grid Grid.Column="0" Width="16" Height="16" Margin="0,2,12,0" VerticalAlignment="Top">
                      <Ellipse Classes="radioRing" Stroke="{DynamicResource SETextFaintBrush}" StrokeThickness="1.5" />
                      <Ellipse Classes="radioDot" Width="8" Height="8"
                               Fill="{DynamicResource SEAccentBrush}" />
                    </Grid>
                    <!-- channel colour dot -->
                    <Ellipse Grid.Column="1" Width="9" Height="9" Margin="0,5,9,0" VerticalAlignment="Top"
                             Fill="{Binding DotBrush}" />
                    <StackPanel Grid.Column="2" Spacing="3">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border Background="{Binding BadgeBg}" CornerRadius="3"
                                Padding="5,1" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Badge}" FontSize="10.5"
                                     FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                     Foreground="{Binding DotBrush}" />
                        </Border>
                      </StackPanel>
                      <TextBlock Text="{Binding Description}" FontSize="11.5" TextWrapping="Wrap"
                                 Foreground="{DynamicResource SETextSecondaryBrush}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Label sits where On/Off would be; the knob state already reads as on/off. -->
          <ToggleSwitch IsChecked="{Binding CheckForUpdatesOnStartup}" Margin="0,4,0,0"
                        OnContent="{Binding Loc[CheckForUpdatesOnStartup]}"
                        OffContent="{Binding Loc[CheckForUpdatesOnStartup]}" />
          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0"
                      IsEnabled="{Binding CheckForUpdatesOnStartup}">
            <TextBlock Text="{Binding Loc[UpdateCheckInterval]}" VerticalAlignment="Center" FontSize="12" />
            <ComboBox ItemsSource="{Binding UpdateIntervals}"
                      SelectedItem="{Binding SelectedUpdateIntervalOption}" MinWidth="160">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2,0,0">
            <Button Content="{Binding Loc[UpdateCheckNow]}" Command="{Binding CheckForUpdatesNowCommand}"
                    IsEnabled="{Binding !IsCheckingUpdate}" />
            <Button Classes="Accent" Content="{Binding Loc[UpdateBannerViewChangelog]}"
                    Command="{Binding ShowWhatsNewCommand}" IsVisible="{Binding Update.HasUpdate}" />
            <TextBlock Text="{Binding UpdateCheckStatus}" VerticalAlignment="Center" FontSize="11.5"
                       Foreground="{DynamicResource SETextSecondaryBrush}" />
          </StackPanel>
          <Button Content="{Binding Loc[UpdateRollback]}" Command="{Binding RollBackUpdateCommand}"
                  IsVisible="{Binding CanRollback}" HorizontalAlignment="Left" Margin="0,2,0,0" />
        </StackPanel>
        </ScrollViewer>

        <!-- Appearance -->
        <StackPanel Spacing="10"
                    IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Appearance}">
          <TextBlock Text="{Binding Loc[SettingsAppearance]}" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Loc[AppearanceDesc]}" FontSize="12" Foreground="{DynamicResource SETextSecondaryBrush}" />
          <TextBlock Text="{Binding Loc[Theme]}" FontWeight="SemiBold" Margin="0,6,0,0" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <RadioButton GroupName="Theme" Content="{Binding Loc[ThemeSystem]}"
                         IsChecked="{Binding Theme, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static settings:AppTheme.System}, Mode=OneWay}"
                         Command="{Binding SetThemeCommand}" CommandParameter="{x:Static settings:AppTheme.System}" />
            <RadioButton GroupName="Theme" Content="{Binding Loc[ThemeLight]}"
                         IsChecked="{Binding Theme, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static settings:AppTheme.Light}, Mode=OneWay}"
                         Command="{Binding SetThemeCommand}" CommandParameter="{x:Static settings:AppTheme.Light}" />
            <RadioButton GroupName="Theme" Content="{Binding Loc[ThemeDark]}"
                         IsChecked="{Binding Theme, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static settings:AppTheme.Dark}, Mode=OneWay}"
                         Command="{Binding SetThemeCommand}" CommandParameter="{x:Static settings:AppTheme.Dark}" />
          </StackPanel>

          <TextBlock Text="{Binding Loc[PanelsSectionTitle]}" FontWeight="SemiBold" Margin="0,10,0,0" />
          <ToggleSwitch IsChecked="{Binding SingleBottomPanel}"
                        OnContent="{Binding Loc[SingleBottomPanel]}" OffContent="{Binding Loc[SingleBottomPanel]}" />
          <TextBlock Text="{Binding Loc[SingleBottomPanelHint]}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextFaintBrush}" Margin="24,0,0,0" />
        </StackPanel>

        <!-- Editor -->
        <StackPanel Spacing="10"
                    IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Editor}">
          <TextBlock Text="{Binding Loc[SettingsEditor]}" FontSize="14" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Loc[EditorFontSize]}" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Width="150"
                           Minimum="8" Maximum="32" Value="{Binding EditorFontSize}" />
          </Grid>
          <ToggleSwitch IsChecked="{Binding EditorWordWrap}"
                        OnContent="{Binding Loc[EditorWordWrap]}" OffContent="{Binding Loc[EditorWordWrap]}" />

          <TextBlock Text="{Binding Loc[FormatSectionTitle]}" FontWeight="SemiBold" Margin="0,10,0,0" />
          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Loc[FormatKeywordCasingLabel]}" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" Width="200" ItemsSource="{Binding KeywordCasings}"
                      SelectedItem="{Binding SelectedKeywordCasingOption}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Loc[FormatIndentLabel]}" VerticalAlignment="Center" />
            <ComboBox Grid.Column="1" Width="200" ItemsSource="{Binding IndentSizes}"
                      SelectedItem="{Binding FormatIndentSize}" />
          </Grid>
        </StackPanel>

        <!-- Query -->
        <StackPanel Spacing="10"
                    IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Query}">
          <TextBlock Text="{Binding Loc[SettingsQuery]}" FontSize="14" FontWeight="SemiBold" />
          <ToggleSwitch IsChecked="{Binding ConfirmBeforeSave}" Margin="0,6,0,0"
                        OnContent="{Binding Loc[ConfirmBeforeSave]}" OffContent="{Binding Loc[ConfirmBeforeSave]}" />
          <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Loc[QueryTimeout]}" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Width="150" Minimum="0" Maximum="86400" FormatString="0"
                           Value="{Binding QueryTimeoutSeconds}" />
          </Grid>
          <TextBlock Text="{Binding Loc[QueryTimeoutHint]}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextFaintBrush}" />
          <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Loc[BrowsePageSize]}" VerticalAlignment="Center" />
            <NumericUpDown Grid.Column="1" Width="150" Minimum="1" Maximum="100000" FormatString="0"
                           Value="{Binding BrowsePageSize}" />
          </Grid>
          <TextBlock Text="{Binding Loc[BrowsePageSizeHint]}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextFaintBrush}" />
        </StackPanel>

        <!-- Query Log -->
        <StackPanel Spacing="8" MaxWidth="560" HorizontalAlignment="Left"
                    IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=QueryLog}">
          <TextBlock Text="{Binding Loc[SettingsQueryLog]}" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Loc[QueryLogDesc]}" FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextSecondaryBrush}" />

          <ToggleSwitch IsChecked="{Binding QueryLogEnabled}" Margin="0,6,0,0"
                        OnContent="{Binding Loc[QueryLogEnabledLabel]}" OffContent="{Binding Loc[QueryLogEnabledLabel]}" />

          <TextBlock Text="{Binding Loc[QueryLogSources]}" FontWeight="SemiBold" Margin="0,4,0,0"
                     IsEnabled="{Binding QueryLogEnabled}" />
          <ToggleSwitch IsChecked="{Binding QueryLogApp}" IsEnabled="{Binding QueryLogEnabled}" Margin="12,0,0,0"
                        OnContent="{Binding Loc[QueryLogAppLabel]}" OffContent="{Binding Loc[QueryLogAppLabel]}" />
          <ToggleSwitch IsChecked="{Binding QueryLogMcp}" IsEnabled="{Binding QueryLogEnabled}" Margin="12,0,0,0"
                        OnContent="{Binding Loc[QueryLogMcpLabel]}" OffContent="{Binding Loc[QueryLogMcpLabel]}" />

          <TextBlock Text="{Binding Loc[QueryLogHint]}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextFaintBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Security (master password) -->
        <StackPanel Spacing="8" MaxWidth="560" HorizontalAlignment="Left"
                    IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Security}">
          <TextBlock Text="{Binding Loc[SettingsSecurity]}" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Loc[MasterPwSectionDesc]}" FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextSecondaryBrush}" />

          <!-- Not set -->
          <StackPanel Spacing="8" IsVisible="{Binding !MasterPasswordEnabled}">
            <TextBlock Text="{Binding Loc[MasterPwNotSet]}" FontSize="12" TextWrapping="Wrap" />
            <Button Content="{Binding Loc[MasterPwSetButton]}" Command="{Binding SetMasterPasswordCommand}"
                    HorizontalAlignment="Left" />
          </StackPanel>

          <!-- Set -->
          <StackPanel Spacing="8" IsVisible="{Binding MasterPasswordEnabled}">
            <TextBlock Text="{Binding Loc[MasterPwIsSet]}" FontSize="12" Foreground="{DynamicResource SEStatusConnectedBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="{Binding Loc[MasterPwChangeButton]}" Command="{Binding ChangeMasterPasswordCommand}" />
              <Button Content="{Binding Loc[MasterPwDisableButton]}" Command="{Binding DisableMasterPasswordCommand}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0" MaxWidth="360" HorizontalAlignment="Left">
              <TextBlock Grid.Column="0" Text="{Binding Loc[MasterPwLockAfter]}" VerticalAlignment="Center" />
              <ComboBox Grid.Column="1" Width="150" SelectedIndex="{Binding MasterPasswordLockIndex, Mode=TwoWay}">
                <ComboBoxItem Content="{Binding Loc[MasterPwLockNever]}" />
                <ComboBoxItem Content="{Binding Loc[MasterPwLock15]}" />
                <ComboBoxItem Content="{Binding Loc[MasterPwLock30]}" />
                <ComboBoxItem Content="{Binding Loc[MasterPwLock60]}" />
              </ComboBox>
            </Grid>
          </StackPanel>

          <TextBlock Text="{Binding MasterPasswordMessage}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                     IsVisible="{Binding MasterPasswordMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <TextBlock Text="{Binding Loc[MasterPwNoRecovery]}" FontSize="11" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextFaintBrush}" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Keyboard -->
        <Grid RowDefinitions="Auto,Auto,Auto,*"
              IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Keyboard}">
          <TextBlock Grid.Row="0" Text="{Binding Loc[SettingsKeyboard]}" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Grid.Row="1" Text="{Binding Loc[KeyboardDesc]}" FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextSecondaryBrush}" Margin="0,4,0,10" />

          <!-- Conflict banner: only while two commands share a gesture (save is blocked meanwhile). -->
          <Border Grid.Row="2" IsVisible="{Binding HasShortcutConflicts}" Margin="0,0,0,10"
                  Background="#22D64545" BorderBrush="#66D64545" BorderThickness="1" CornerRadius="5" Padding="10,6">
            <TextBlock Text="{Binding Loc[ShortcutConflictBanner]}" FontSize="12" Foreground="#F0B4B4" TextWrapping="Wrap" />
          </Border>

          <Border Grid.Row="3" BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1" CornerRadius="6">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding ShortcutGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel>
                      <!-- Group header (Tabs/Query/Editor/Search) -->
                      <TextBlock Text="{Binding Label}" FontSize="10.5" FontWeight="SemiBold" Margin="12,9,12,5"
                                 Foreground="{DynamicResource SETextSecondaryBrush}" />
                      <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto,Auto" Height="42" Margin="12,0"
                                  Background="Transparent">
                              <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                <TextBlock Text="{Binding Label}" FontSize="12.5" />
                                <TextBlock Text="{Binding ConflictWith, StringFormat='Conflicts with “{0}”'}"
                                           IsVisible="{Binding HasConflict}" FontSize="11"
                                           Foreground="{DynamicResource SEStatusErrorBrush}" />
                              </StackPanel>

                              <!-- Click-to-capture chip -->
                              <ctl:ShortcutCaptureBox Grid.Column="1" MinWidth="130" VerticalAlignment="Center"
                                                      HorizontalContentAlignment="Center"
                                                      Gesture="{Binding Gesture, Mode=TwoWay}"
                                                      CapturingText="{Binding $parent[Window].DataContext.Loc[ShortcutPressKeys]}"
                                                      UnboundText="{Binding $parent[Window].DataContext.Loc[ShortcutUnbound]}"
                                                      Classes.conflict="{Binding HasConflict}" />

                              <!-- Reset-to-default (only once changed) -->
                              <Button Grid.Column="2" Classes="Subtle" Width="28" Height="28" Padding="0"
                                      Margin="6,0,0,0" VerticalAlignment="Center"
                                      IsVisible="{Binding IsChanged}"
                                      Command="{Binding ResetCommand}"
                                      ToolTip.Tip="{Binding $parent[Window].DataContext.Loc[ShortcutResetTooltip]}">
                                <Path Width="14" Height="14" Stretch="Uniform"
                                      Data="M3,8 A5,5 0 1 1 4.6,11.7 M3,5 V8 H6"
                                      Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.4"
                                      StrokeJoin="Round" StrokeLineCap="Round" />
                              </Button>
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </Grid>

        <!-- MCP server (AI query access) -->
        <ScrollViewer IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Mcp}">
          <StackPanel Spacing="10" MaxWidth="560" HorizontalAlignment="Left">
            <TextBlock Text="{Binding Loc[SettingsMcp]}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Loc[McpDesc]}" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource SETextSecondaryBrush}" />

            <ToggleSwitch IsChecked="{Binding McpEnabled}" Margin="0,6,0,0"
                          OnContent="{Binding Loc[McpEnabled]}" OffContent="{Binding Loc[McpEnabled]}" />

            <!-- Live status + Start/Stop, only while MCP is enabled (SE-147). The knob's master-switch stays
                 the launch/Save behaviour; this is runtime control for the current session. -->
            <Border IsVisible="{Binding McpEnabled}"
                    Background="{DynamicResource SEPanelBgBrush}" CornerRadius="5" Padding="10,8">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="●" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#3FB950" IsVisible="{Binding McpRunning}" />
                <TextBlock Grid.Column="0" Text="○" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource SETextFaintBrush}" IsVisible="{Binding !McpRunning}" />
                <TextBlock Grid.Column="1" Text="{Binding McpStatusText}" VerticalAlignment="Center"
                           FontSize="12" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="2" Classes="Accent" Margin="8,0,0,0" MinWidth="76"
                        HorizontalContentAlignment="Center"
                        Content="{Binding McpToggleLabel}" Command="{Binding ToggleMcpServerCommand}" />
              </Grid>
            </Border>

            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
              <TextBlock Grid.Column="0" Text="{Binding Loc[McpPort]}" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1" Width="150" Minimum="1024" Maximum="65535" FormatString="0"
                             Value="{Binding McpPort}" />
            </Grid>
            <TextBlock Text="{Binding Loc[McpBindHint]}" FontSize="11" Foreground="{DynamicResource SETextFaintBrush}" />

            <!-- Server URL: read-only, copy. Reflects the loopback bind + selected port. -->
            <StackPanel Spacing="4" Margin="0,6,0,0">
              <TextBlock Text="{Binding Loc[McpUrl]}" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding McpUrl}" IsReadOnly="True"
                         FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="12" />
                <Button Grid.Column="1" Margin="6,0,0,0" Content="{Binding Loc[Copy]}" Click="OnCopyMcpUrlClick" />
              </Grid>
            </StackPanel>

            <ToggleSwitch IsChecked="{Binding McpRequireAuth}" Margin="0,6,0,0"
                          OnContent="{Binding Loc[McpRequireAuth]}" OffContent="{Binding Loc[McpRequireAuth]}" />

            <!-- No-auth warning (plan §6): non-dismissible while auth is off. -->
            <Border IsVisible="{Binding ShowNoAuthWarning}"
                    Background="#22D6A545" BorderBrush="#66D6A545" BorderThickness="1" CornerRadius="5" Padding="10,6">
              <TextBlock Text="{Binding Loc[McpNoAuthWarning]}" FontSize="12" Foreground="#E7C77A" TextWrapping="Wrap" />
            </Border>

            <!-- Bearer token: read-only, copy + regenerate. Only meaningful when auth is on. -->
            <StackPanel Spacing="4" IsVisible="{Binding McpRequireAuth}">
              <TextBlock Text="{Binding Loc[McpToken]}" FontWeight="SemiBold" Margin="0,6,0,0" />
              <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Text="{Binding McpToken}" IsReadOnly="True"
                         FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="12"
                         PlaceholderText="{Binding Loc[McpTokenEmpty]}" />
                <Button Grid.Column="1" Margin="6,0,0,0" Content="{Binding Loc[Copy]}" Click="OnCopyMcpTokenClick" />
                <Button Grid.Column="2" Margin="6,0,0,0" Content="{Binding Loc[McpRegenerate]}"
                        Command="{Binding RegenerateMcpTokenCommand}" />
              </Grid>
              <TextBlock Text="{Binding Loc[McpTokenHint]}" FontSize="11" Foreground="{DynamicResource SETextFaintBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <TextBlock Text="{Binding Loc[McpCaps]}" FontWeight="SemiBold" Margin="0,10,0,0" />
            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
              <TextBlock Grid.Column="0" Text="{Binding Loc[McpMaxRows]}" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1" Width="150" Minimum="1" Maximum="100000" FormatString="0"
                             Value="{Binding McpMaxRows}" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding Loc[McpTimeout]}" VerticalAlignment="Center" />
              <NumericUpDown Grid.Column="1" Width="150" Minimum="1" Maximum="3600" FormatString="0"
                             Value="{Binding McpTimeoutSeconds}" />
            </Grid>

            <!-- Label sits where On/Off would be; the knob state already reads as on/off. -->
            <ToggleSwitch IsChecked="{Binding McpScrubSecrets}" Margin="0,10,0,0"
                          OnContent="{Binding Loc[McpScrubSecrets]}"
                          OffContent="{Binding Loc[McpScrubSecrets]}" />
            <TextBlock Text="{Binding Loc[McpScrubSecretsHint]}" FontSize="11"
                       Foreground="{DynamicResource SETextFaintBrush}" TextWrapping="Wrap" />

            <!-- Warning while scrubbing is off: live secrets in results may reach the AI (SE-145). -->
            <Border IsVisible="{Binding ShowNoScrubWarning}"
                    Background="#22D6A545" BorderBrush="#66D6A545" BorderThickness="1" CornerRadius="5" Padding="10,6">
              <TextBlock Text="{Binding Loc[McpNoScrubWarning]}" FontSize="12" Foreground="#E7C77A" TextWrapping="Wrap" />
            </Border>

            <!-- ── Connection creation (SE-155) ── -->
            <TextBlock Text="{Binding Loc[McpConnectionCreateTitle]}" FontWeight="SemiBold" Margin="0,12,0,0" />
            <ToggleSwitch IsChecked="{Binding McpAllowConnectionCreate}" Margin="0,2,0,0"
                          OnContent="{Binding Loc[McpAllowConnectionCreate]}"
                          OffContent="{Binding Loc[McpAllowConnectionCreate]}" />
            <TextBlock Text="{Binding Loc[McpAllowConnectionCreateHint]}" FontSize="11"
                       Foreground="{DynamicResource SETextFaintBrush}" TextWrapping="Wrap" />

            <!-- Loud warning while AI connection-creation is enabled. -->
            <Border IsVisible="{Binding ShowConnectionCreateWarning}"
                    Background="#22D6A545" BorderBrush="#66D6A545" BorderThickness="1" CornerRadius="5" Padding="10,6">
              <TextBlock Text="{Binding Loc[McpConnectionCreateWarning]}" FontSize="12" Foreground="#E7C77A" TextWrapping="Wrap" />
            </Border>

            <StackPanel Spacing="6" IsVisible="{Binding McpAllowConnectionCreate}" Margin="0,4,0,0">
              <!-- Folder that AI-created connections are grouped under. -->
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Loc[McpConnectionFolder]}" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Width="200" Text="{Binding McpConnectionFolder}" />
              </Grid>

              <!-- Extra allowed hosts (loopback is always allowed). Same editor pattern as plugin sources. -->
              <TextBlock Text="{Binding Loc[McpAllowedHosts]}" FontWeight="SemiBold" Margin="0,4,0,0" />
              <TextBlock Text="{Binding Loc[McpAllowedHostsHint]}" FontSize="11.5" TextWrapping="Wrap"
                         Foreground="{DynamicResource SETextSecondaryBrush}" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" PlaceholderText="{Binding Loc[McpAllowedHostAddHint]}" Text="{Binding NewAllowedHost}" />
                <Button Grid.Column="1" Classes="Subtle" Margin="8,0,0,0" Content="{Binding Loc[Add]}" Command="{Binding AddAllowedHostCommand}" />
              </Grid>
              <TextBlock Text="{Binding HostError}" IsVisible="{Binding HasHostError}" FontSize="11.5"
                         TextWrapping="Wrap" Foreground="{DynamicResource SEStatusErrorBrush}" />
              <ItemsControl ItemsSource="{Binding McpAllowedHosts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="Card" Background="{DynamicResource SEPanelBgBrush}">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"
                                   FontSize="11.5" FontFamily="Cascadia Code,Menlo,Consolas,monospace" />
                        <Button Grid.Column="1" Classes="Subtle" Content="{Binding $parent[Window].DataContext.Loc[Remove]}"
                                Command="{Binding $parent[Window].DataContext.RemoveAllowedHostCommand}" CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>

        <!-- Plugins -->
        <Grid RowDefinitions="Auto,Auto,Auto,*"
              IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Plugins}">
          <TextBlock Grid.Row="0" Text="{Binding Loc[SettingsPlugins]}" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Grid.Row="1" Text="{Binding Loc[PluginsDesc]}" FontSize="12" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextSecondaryBrush}" Margin="0,4,0,12" />

          <!-- Proactive plugin-update policy (SE-138) -->
          <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
            <TextBlock Text="{Binding Loc[PluginUpdatePolicyLabel]}" VerticalAlignment="Center" />
            <ComboBox MinWidth="200" ItemsSource="{Binding PluginUpdatePolicies}"
                      SelectedItem="{Binding SelectedPluginUpdatePolicyOption}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <!-- Empty state -->
          <TextBlock Grid.Row="3" IsVisible="{Binding !HasPlugins}"
                     Text="{Binding Loc[PluginsNoneHint]}" TextWrapping="Wrap"
                     Foreground="{DynamicResource SETextFaintBrush}" VerticalAlignment="Top" />

          <!-- Master-detail -->
          <Border Grid.Row="3" IsVisible="{Binding HasPlugins}"
                  BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1" CornerRadius="6">
            <Grid ColumnDefinitions="230,Auto,*">
              <ListBox Grid.Column="0" Background="{DynamicResource SEPanelBgBrush}"
                       ItemsSource="{Binding Plugins}" SelectedItem="{Binding SelectedPlugin}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="7">
                      <Image Width="16" Height="16" VerticalAlignment="Center"
                             RenderOptions.BitmapInterpolationMode="HighQuality"
                             Source="{Binding Icon}" IsVisible="{Binding HasImageIcon}" />
                      <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Data="{Binding FallbackIcon}"
                            Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.3"
                            StrokeJoin="Round" StrokeLineCap="Round" IsVisible="{Binding !HasImageIcon}" />
                      <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <GridSplitter Grid.Column="1" Width="1" Background="{DynamicResource SEHairlineBrush}" />

              <ScrollViewer Grid.Column="2" DataContext="{Binding SelectedPlugin}">
                <StackPanel Margin="18,16" Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Border Background="{DynamicResource SEToolbarBgBrush}" CornerRadius="9" Padding="7,2"
                            VerticalAlignment="Center">
                      <!-- <TextBlock Text="{Binding RouteLabel}" FontSize="10" -->
                      <!--            Foreground="{DynamicResource SETextSecondaryBrush}" /> -->
                    </Border>
                  </StackPanel>

                  <!-- Route A: host-rendered fields -->
                  <ItemsControl ItemsSource="{Binding Fields}" ItemTemplate="{StaticResource PluginFieldTemplate}"
                                IsVisible="{Binding HasFields}" Margin="0,8,0,0" />

                  <!-- Route B: the plugin's own view -->
                  <ContentControl Content="{Binding CustomView}" IsVisible="{Binding HasCustomView}" Margin="0,8,0,0" />
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Border>
        </Grid>

        <!-- ===== Plugin Sources pane (SE-122, relocated from Plugin Store's Sources tab) ===== -->
        <ScrollViewer IsVisible="{Binding ActiveCategoryKey, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=PluginSources}">
          <StackPanel Margin="24,20" Spacing="20">
            <!-- Discovery (read-only) -->
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding Loc[StoreDiscoverySources]}" FontSize="13" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Loc[StoreDiscoveryDesc]}" FontSize="11.5" TextWrapping="Wrap"
                         Foreground="{DynamicResource SETextSecondaryBrush}" />
              <ItemsControl ItemsSource="{Binding DiscoverySources}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="Card" Background="{DynamicResource SEPanelBgBrush}">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <Image Grid.Column="0" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center"
                               RenderOptions.BitmapInterpolationMode="HighQuality"
                               Source="{Binding Icon}" IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5" />
                          <TextBlock Text="{Binding Url}" FontSize="10.5" FontFamily="Cascadia Code,Menlo,Consolas,monospace"
                                     Foreground="{DynamicResource SETextFaintBrush}" />
                          <TextBlock Text="{Binding Error}" FontSize="10.5" Foreground="{DynamicResource SEStatusErrorBrush}"
                                     IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>
                        <Ellipse Grid.Column="2" Width="8" Height="8" VerticalAlignment="Center"
                                 Fill="{Binding Ok, Converter={x:Static c:BoolToStatusBrushConverter.Instance}}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- Manual -->
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding Loc[StoreManualSources]}" FontSize="13" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Loc[StoreManualHint]}" FontSize="11.5" TextWrapping="Wrap"
                         Foreground="{DynamicResource SETextSecondaryBrush}" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" PlaceholderText="{Binding Loc[StoreAddSourceHint]}" Text="{Binding NewSourceUrl}" />
                <Button Grid.Column="1" Classes="Subtle" Margin="8,0,0,0" Content="{Binding Loc[Add]}" Command="{Binding AddManualSourceCommand}" />
              </Grid>
              <TextBlock Text="{Binding SourceError}" IsVisible="{Binding HasSourceError}" FontSize="11.5"
                         TextWrapping="Wrap" Foreground="{DynamicResource SEStatusErrorBrush}" />
              <ItemsControl ItemsSource="{Binding ManualSources}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="Card" Background="{DynamicResource SEPanelBgBrush}">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0" VerticalAlignment="Center"
                                 Fill="{Binding Ok, Converter={x:Static c:BoolToStatusBrushConverter.Instance}}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                          <TextBlock Text="{Binding Url}" FontSize="11.5" FontFamily="Cascadia Code,Menlo,Consolas,monospace" />
                          <TextBlock Text="{Binding Error}" FontSize="10.5" Foreground="{DynamicResource SEStatusErrorBrush}"
                                     IsVisible="{Binding Error, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>
                        <Button Grid.Column="2" Classes="Subtle" Content="{Binding $parent[Window].DataContext.Loc[Remove]}"
                                Command="{Binding $parent[Window].DataContext.RemoveManualSourceCommand}" CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Panel>

      <!-- Footer -->
      <Grid Grid.Row="1" Margin="24,0,24,16" ColumnDefinitions="Auto,*,Auto,Auto,Auto">
        <Button Grid.Column="0" Classes="Subtle" Content="{Binding Loc[RestoreDefaults]}" Command="{Binding RestoreDefaultsCommand}" />
        <Button Grid.Column="2" Classes="Subtle" Content="{Binding Loc[Cancel]}" Command="{Binding CancelCommand}" Margin="0,0,8,0" />
        <Button Grid.Column="3" Content="{Binding Loc[Apply]}" Command="{Binding ApplyCommand}" Margin="0,0,8,0" />
        <Button Grid.Column="4" Classes="Accent" Content="{Binding Loc[ApplyAndClose]}" Command="{Binding ApplyAndCloseCommand}" IsDefault="True" />
      </Grid>
    </Grid>
  </Grid>
</Window>
