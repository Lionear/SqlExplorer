<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:SqlExplorer.App.Converters"
        xmlns:plugins="using:SqlExplorer.Core.Plugins"
        x:Class="SqlExplorer.App.Views.PluginStoreWindow"
        Title="{Binding Loc[PluginStoreTitle]}"
        Width="920" Height="640" MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner">

  <Window.Resources>
    <!-- One Installed-tab row: metadata + status chips + per-plugin actions. Bundled rows expose no
         manage actions; a failed load paints the whole row red so it stands out in a long list. -->
    <DataTemplate x:Key="InstalledRow">
      <Border Classes="Card" Classes.error="{Binding HasLoadError}" Background="{DynamicResource SEPanelBgBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- Icon box (remote icon or vector fallback) -->
          <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" VerticalAlignment="Center"
                  Margin="0,0,11,0" Background="{DynamicResource SEToolbarBgBrush}">
            <Panel>
              <Image Width="18" Height="18" RenderOptions.BitmapInterpolationMode="HighQuality" Source="{Binding Icon}"
                     IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
              <Path Width="15" Height="15" Stretch="Uniform"
                    Data="M3,3 H7 V7 H3 Z M9,3 H13 V7 H9 Z M3,9 H7 V13 H3 Z M9,9 H13 V13 H9 Z"
                    Stroke="{DynamicResource SETextFaintBrush}" StrokeThickness="1.2"
                    IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}" />
            </Panel>
          </Border>

          <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Version}" FontSize="11" VerticalAlignment="Center"
                         FontFamily="Cascadia Code,Menlo,Consolas,monospace"
                         Foreground="{DynamicResource SETextFaintBrush}" />
              <Border IsVisible="{Binding UpdateAvailable}" Background="#2EE0A33E" CornerRadius="9"
                      Padding="7,1" VerticalAlignment="Center">
                <TextBlock Text="{Binding UpdateLabel}" FontSize="9.5" FontWeight="SemiBold"
                           Foreground="{DynamicResource SEStatusWaitingBrush}" />
              </Border>
              <!-- Version-pin badge: this plugin is held at its current version by IPluginPinStore
                   until the user clicks Unpin (SE-120). -->
              <Border IsVisible="{Binding IsPinned}" Background="#2E3574F0" CornerRadius="9"
                      Padding="7,1" VerticalAlignment="Center">
                <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StorePinned]}" FontSize="9.5"
                           FontWeight="SemiBold" Foreground="{DynamicResource SEAccentBrush}" />
              </Border>
            </StackPanel>
            <!-- status line -->
            <TextBlock Text="{Binding LoadError}" FontSize="11" TextWrapping="Wrap"
                       Foreground="{DynamicResource SEStatusErrorBrush}" IsVisible="{Binding HasLoadError}" />
            <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StorePendingRemove]}" FontSize="11"
                       Foreground="{DynamicResource SEStatusWaitingBrush}"
                       IsVisible="{Binding Pending, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static plugins:PluginPendingAction.Remove}}" />
            <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StorePendingInstall]}" FontSize="11"
                       Foreground="{DynamicResource SEAccentBrush}"
                       IsVisible="{Binding Pending, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter={x:Static plugins:PluginPendingAction.Install}}" />
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Classes="Accent" IsVisible="{Binding UpdateAvailable}"
                    Content="{Binding UpdateLabel}"
                    Command="{Binding $parent[Window].DataContext.UpdateCommand}" CommandParameter="{Binding}" />
            <Button Classes="Subtle" IsVisible="{Binding HasChangelog}"
                    Content="{Binding $parent[Window].DataContext.Loc[PluginUpdatesViewChangelog]}"
                    Command="{Binding $parent[Window].DataContext.ViewChangelogCommand}" CommandParameter="{Binding}" />
            <Button Classes="Subtle" IsVisible="{Binding HasRollback}"
                    Content="{Binding RollbackLabel}"
                    Command="{Binding $parent[Window].DataContext.RollbackCommand}" CommandParameter="{Binding}" />
            <Button Classes="Subtle" IsVisible="{Binding IsPinned}"
                    Content="{Binding $parent[Window].DataContext.Loc[StoreUnpin]}"
                    Command="{Binding $parent[Window].DataContext.UnpinCommand}" CommandParameter="{Binding}" />
            <Button Classes="Subtle" IsVisible="{Binding CanManage}"
                    Content="{Binding $parent[Window].DataContext.Loc[StoreUninstall]}"
                    Command="{Binding $parent[Window].DataContext.UninstallCommand}" CommandParameter="{Binding}" />
            <!-- Built-in: no actions, just a chip -->
            <Border IsVisible="{Binding !CanManage}" Background="#2E5AA576" CornerRadius="9" Padding="8,2"
                    VerticalAlignment="Center">
              <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StoreBuiltIn]}" FontSize="9.5"
                         FontWeight="SemiBold" Foreground="{DynamicResource SEStatusConnectedBrush}" />
            </Border>
            <!-- Enable/disable toggle (user plugins only) -->
            <ToggleSwitch IsVisible="{Binding CanManage}" IsChecked="{Binding Enabled, Mode=OneWay}"
                          OnContent="" OffContent="" VerticalAlignment="Center"
                          Command="{Binding $parent[Window].DataContext.ToggleEnabledCommand}" CommandParameter="{Binding}" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <!-- Tabstrip buttons: an accent underline on the selected tab. -->
    <Style Selector="Button.Tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="14,8" />
    </Style>
    <Style Selector="Button.Tab.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource SEAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource SEAccentBrush}" />
    </Style>

    <!-- Category-filter chips inside Browse: compact pill buttons with a subtle background;
         VS Code / JetBrains / DBeaver pattern. Selected = accent-filled. -->
    <Style Selector="Button.Chip">
      <Setter Property="Background" Value="{DynamicResource SEToolbarBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SEHairlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="9,3" />
      <Setter Property="FontSize" Value="11.5" />
    </Style>
    <Style Selector="Button.Chip.selected">
      <Setter Property="Background" Value="{DynamicResource SEAccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SEAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource SEAccentFgBrush}" />
    </Style>

    <!-- Store-local: give Subtle buttons a visible border/fill here so row actions read as buttons
         (the app-wide Subtle is intentionally borderless text; the tabstrip uses its own .Tab class). -->
    <Style Selector="Button.Subtle">
      <Setter Property="Background" Value="{DynamicResource SEToolbarBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SEHairlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="10,5" />
    </Style>
    <Style Selector="Button.Subtle:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SEHoverBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SETextFaintBrush}" />
    </Style>

    <Style Selector="Border.Card">
      <Setter Property="Background" Value="{DynamicResource SEPanelBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SEHairlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <!-- Selected browse card: accent border + faint accent tint (mockup .card.selected). -->
    <Style Selector="Border.Card.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource SEAccentBrush}" />
      <Setter Property="Background" Value="#143574F0" />
    </Style>
    <Style Selector="Border.Card.error">
      <Setter Property="BorderBrush" Value="#66D64545" />
      <Setter Property="Background" Value="#18D64545" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

    <!-- ===== Header: breadcrumb + tabstrip + actions ===== -->
    <Border Grid.Row="0" Background="{DynamicResource SEToolbarBgBrush}"
            BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,0,0,1">
      <Grid Margin="16,10,16,0" RowDefinitions="Auto,Auto">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
          <TextBlock Text="{Binding Loc[Tools]}" Foreground="{DynamicResource SETextFaintBrush}" FontSize="12" />
          <TextBlock Text="›" Foreground="{DynamicResource SETextFaintBrush}" FontSize="12" />
          <TextBlock Text="{Binding Loc[PluginStoreTitle]}" FontSize="12" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Classes="Tab" Classes.selected="{Binding SelectedTab, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Browse}"
                    Content="{Binding Loc[StoreTabBrowse]}" Command="{Binding SelectTabCommand}" CommandParameter="Browse" />
            <Button Classes="Tab" Classes.selected="{Binding SelectedTab, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Installed}"
                    Command="{Binding SelectTabCommand}" CommandParameter="Installed">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="{Binding Loc[StoreTabInstalled]}" />
                <TextBlock Text="{Binding InstalledCount}" FontSize="10.5" VerticalAlignment="Center"
                           Foreground="{DynamicResource SETextFaintBrush}" />
              </StackPanel>
            </Button>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,0,6">
            <Button Classes="Subtle" Content="{Binding Loc[StoreManageSources]}" Command="{Binding ManageSourcesCommand}" />
            <Button Classes="Subtle" Content="{Binding Loc[Refresh]}" Command="{Binding RefreshCommand}" />
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <!-- ===== Restart-needed banner (amber, per mockup state 10) ===== -->
    <Border Grid.Row="1" IsVisible="{Binding RestartRequired}" Background="#1FE0A33E"
            BorderBrush="#59E0A33E" BorderThickness="0,0,0,1" Padding="16,7">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding Loc[StoreRestartNeeded]}" Foreground="{DynamicResource SEStatusWaitingBrush}"
                   FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
        <Button Grid.Column="1" Classes="Subtle" VerticalAlignment="Center"
                Content="{Binding Loc[StoreRestartApp]}" Command="{Binding RestartAppCommand}" />
      </Grid>
    </Border>

    <!-- ===== Error banner ===== -->
    <Border Grid.Row="2" IsVisible="{Binding ErrorText, Converter={x:Static ObjectConverters.IsNotNull}}"
            Background="#22D64545" BorderBrush="#66D64545" BorderThickness="0,0,0,1" Padding="16,8">
      <TextBlock Text="{Binding ErrorText}" Foreground="#F0B4B4" FontSize="12" TextWrapping="Wrap" />
    </Border>

    <!-- ===== Content ===== -->
    <Panel Grid.Row="3">

      <!-- ===== BROWSE (per-category tabs share one content pane; ApplyBrowseFilter picks the type) ===== -->
      <Grid ColumnDefinitions="360,*"
            IsVisible="{Binding IsBrowseTabActive}">
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
          <TextBox Grid.Row="0" Margin="12,10,12,6" PlaceholderText="{Binding Loc[StoreSearch]}" Text="{Binding SearchText}" />
          <!-- Type-filter dropdown (SE-157, replacing the old chip row): compact and scalable as new
               types appear. Options + counts come from CategoryOptions; selection bridges SelectedCategory. -->
          <ComboBox Grid.Row="1" Margin="12,0,12,8" HorizontalAlignment="Stretch"
                    ItemsSource="{Binding CategoryOptions}" SelectedItem="{Binding SelectedCategoryOption}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Grid.Row="2" IsVisible="{Binding IsLoading}" Margin="16" Text="{Binding Loc[StoreLoading]}"
                     Foreground="{DynamicResource SETextFaintBrush}" />
          <ScrollViewer Grid.Row="2" IsVisible="{Binding !IsLoading}">
            <ItemsControl ItemsSource="{Binding BrowseItems}" Margin="12,0,12,12">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="Card" Classes.selected="{Binding IsSelected}"
                          PointerPressed="OnBrowseCardPressed" Cursor="Hand">
                    <Grid ColumnDefinitions="Auto,*">
                      <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" VerticalAlignment="Top"
                              Background="{DynamicResource SEToolbarBgBrush}">
                        <Panel>
                          <Image Width="20" Height="20" RenderOptions.BitmapInterpolationMode="HighQuality" Source="{Binding Icon}"
                                 IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                          <Path Width="16" Height="16" Stretch="Uniform"
                                Data="M3,3 H7 V7 H3 Z M9,3 H13 V7 H9 Z M3,9 H7 V13 H3 Z M9,9 H13 V13 H9 Z"
                                Stroke="{DynamicResource SETextFaintBrush}" StrokeThickness="1.2"
                                IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNull}}" />
                        </Panel>
                      </Border>
                      <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="3">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                          <Border IsVisible="{Binding IsBundle}" Background="{DynamicResource SEAccentBrush}"
                                  CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StoreBundleChip]}"
                                       FontSize="9.5" Foreground="{DynamicResource SEAccentFgBrush}" />
                          </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding SubLine}" FontSize="11" Foreground="{DynamicResource SETextFaintBrush}"
                                   FontFamily="Cascadia Code,Menlo,Consolas,monospace" />
                        <TextBlock Text="{Binding Description}" FontSize="11.5" TextWrapping="Wrap" MaxLines="2"
                                   Foreground="{DynamicResource SETextSecondaryBrush}" />
                        <Border IsVisible="{Binding HasSource}" HorizontalAlignment="Left" Margin="0,4,0,0"
                                Background="{DynamicResource SEToolbarBgBrush}" CornerRadius="9" Padding="7,2">
                          <TextBlock Text="{Binding SourceName}" FontSize="9.5" Foreground="{DynamicResource SETextFaintBrush}" />
                        </Border>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>

        <!-- Detail pane -->
        <Border Grid.Column="1" BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1,0,0,0">
          <ScrollViewer DataContext="{Binding SelectedBrowseItem}">
            <StackPanel Margin="22,18" Spacing="10" IsVisible="{Binding Converter={x:Static ObjectConverters.IsNotNull}}">
              <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding Author}" FontSize="11.5" Foreground="{DynamicResource SETextSecondaryBrush}"
                           IsVisible="{Binding Author, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <TextBlock Text="{Binding SourceName}" FontSize="11.5" Foreground="{DynamicResource SETextFaintBrush}"
                           IsVisible="{Binding SourceName, Converter={x:Static ObjectConverters.IsNotNull}}" />
              </StackPanel>
              <TextBlock Text="{Binding Description}" FontSize="12.5" TextWrapping="Wrap" />

              <!-- Bundle: contained plugins -->
              <StackPanel Spacing="4" IsVisible="{Binding IsBundle}">
                <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StoreContains]}" FontSize="11"
                           FontWeight="SemiBold" Foreground="{DynamicResource SETextSecondaryBrush}" />
                <Border BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1" CornerRadius="6">
                  <ItemsControl ItemsSource="{Binding BundleChildren}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Margin="12,8">
                          <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" />
                          <TextBlock Grid.Column="1" Text="{Binding Version}" FontSize="11"
                                     FontFamily="Cascadia Code,Menlo,Consolas,monospace"
                                     Foreground="{DynamicResource SETextFaintBrush}" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
              </StackPanel>

              <!-- Version label -->
              <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StoreVersionLabel]}" FontSize="11"
                         FontWeight="SemiBold" Foreground="{DynamicResource SETextSecondaryBrush}"
                         IsVisible="{Binding !IsBundle}" Margin="0,4,0,0" />

              <!-- Version + action -->
              <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding !IsBundle}">
                <ComboBox MinWidth="140" ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Version}" FontFamily="Cascadia Code,Menlo,Consolas,monospace" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Classes="Accent" Content="{Binding ActionLabel}" IsEnabled="{Binding CanInstall}"
                        Command="{Binding $parent[Window].DataContext.InstallCommand}" CommandParameter="{Binding}" />
                <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StoreStaged]}" IsVisible="{Binding IsStaged}"
                           VerticalAlignment="Center" FontSize="11.5" Foreground="{DynamicResource SEStatusConnectedBrush}" />
              </StackPanel>

              <!-- Bundle install-all -->
              <Button Classes="Accent" IsVisible="{Binding IsBundle}" Content="{Binding ActionLabel}"
                      Command="{Binding $parent[Window].DataContext.InstallCommand}" CommandParameter="{Binding}" />

              <TextBlock Text="{Binding IncompatibleReason}" FontSize="11.5" TextWrapping="Wrap"
                         Foreground="{DynamicResource SEStatusWaitingBrush}"
                         IsVisible="{Binding IncompatibleReason, Converter={x:Static ObjectConverters.IsNotNull}}" />

              <!-- Capabilities -->
              <StackPanel Spacing="4" IsVisible="{Binding Capabilities.Count}">
                <TextBlock Text="{Binding $parent[Window].DataContext.Loc[StoreCapabilities]}" FontSize="11"
                           FontWeight="SemiBold" Foreground="{DynamicResource SETextSecondaryBrush}" />
                <ItemsControl ItemsSource="{Binding Capabilities}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" FontSize="11.5" Foreground="{DynamicResource SETextSecondaryBrush}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <TextBlock Text="{Binding Homepage}" FontSize="11.5" Foreground="{DynamicResource SEAccentBrush}"
                         IsVisible="{Binding Homepage, Converter={x:Static ObjectConverters.IsNotNull}}" />

              <!-- Provenance: checksum · size · source URL -->
              <TextBlock Text="{Binding ProvenanceLine}" FontSize="10.5" TextWrapping="Wrap" Margin="0,6,0,0"
                         FontFamily="Cascadia Code,Menlo,Consolas,monospace" Foreground="{DynamicResource SETextFaintBrush}"
                         IsVisible="{Binding ProvenanceLine, Converter={x:Static ObjectConverters.IsNotNull}}" />
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <!-- ===== INSTALLED ===== -->
      <Grid RowDefinitions="Auto,*"
            IsVisible="{Binding SelectedTab, Converter={x:Static c:EqualsConverter.Instance}, ConverterParameter=Installed}">
        <Grid Grid.Row="0" Margin="16,12" ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0" Text="{Binding InstalledCountLabel}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="Accent" IsVisible="{Binding HasUpdates}" Margin="0,0,8,0"
                  Content="{Binding UpdateAllLabel}" Command="{Binding UpdateAllCommand}" />
          <Button Grid.Column="2" Classes="Subtle" Content="{Binding Loc[StoreInstallFromFile]}" Command="{Binding InstallFromFileCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1">
          <StackPanel Margin="16,0,16,16" Spacing="14">
            <!-- Updates: plugins with an available update, grouped at the top (SE-156) and excluded from the
                 sections below so they never show twice. -->
            <StackPanel Spacing="6" IsVisible="{Binding HasUpdates}">
              <TextBlock Text="{Binding Loc[StoreUpdatesSection]}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource SETextSecondaryBrush}" />
              <ItemsControl ItemsSource="{Binding UpdatablePlugins}" ItemTemplate="{StaticResource InstalledRow}" />
            </StackPanel>
            <!-- Bundled -->
            <StackPanel Spacing="6" IsVisible="{Binding HasBundledPlugins}">
              <TextBlock Text="{Binding Loc[StoreBuiltIn]}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource SETextSecondaryBrush}" />
              <ItemsControl ItemsSource="{Binding BundledPlugins}" ItemTemplate="{StaticResource InstalledRow}" />
            </StackPanel>
            <!-- User-installed -->
            <StackPanel Spacing="6" IsVisible="{Binding HasUserPlugins}">
              <TextBlock Text="{Binding Loc[StoreInstalledSection]}" FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource SETextSecondaryBrush}" />
              <ItemsControl ItemsSource="{Binding UserPlugins}" ItemTemplate="{StaticResource InstalledRow}" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Grid>

    </Panel>

    <!-- ===== Busy / progress panel: a mini install log + the progress bar ===== -->
    <Border Grid.Row="4" IsVisible="{Binding IsBusy}" Background="{DynamicResource SEToolbarBgBrush}"
            BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,1,0,0" Padding="16,12">
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding BusyText}" FontSize="11.5" FontWeight="SemiBold" />
        <Border Background="#12000000" BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1"
                CornerRadius="5" Padding="10,7" MaxHeight="110">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding ProgressLog}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" FontSize="11" LineHeight="17"
                             FontFamily="Cascadia Code,Menlo,Consolas,monospace"
                             Foreground="{DynamicResource SEStatusConnectedBrush}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
        <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressValue}" IsIndeterminate="{Binding ProgressIndeterminate}" />
      </StackPanel>
    </Border>

    <!-- ===== Capability-consent overlay ===== -->
    <Border Grid.Row="0" Grid.RowSpan="5" IsVisible="{Binding IsConsentVisible}" Background="#99000000">
      <Border Background="{DynamicResource SEPanelBgBrush}" BorderBrush="{DynamicResource SEHairlineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="22" MaxWidth="460"
              HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding Loc[StoreConsentTitle]}" FontSize="15" FontWeight="SemiBold" />
          <TextBlock Text="{Binding ConsentPluginName}" FontSize="12.5" Foreground="{DynamicResource SETextSecondaryBrush}" />
          <TextBlock Text="{Binding Loc[StoreConsentBody]}" FontSize="12" TextWrapping="Wrap" />
          <Border Background="{DynamicResource SEToolbarBgBrush}" CornerRadius="6" Padding="12,10">
            <ItemsControl ItemsSource="{Binding ConsentCapabilities}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="Auto,*" Margin="0,3">
                    <TextBlock Grid.Column="0" Text="•" FontSize="12" Margin="0,0,8,0"
                               Foreground="{DynamicResource SEAccentBrush}" />
                    <StackPanel Grid.Column="1" Spacing="1">
                      <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap"
                                 Foreground="{DynamicResource SETextSecondaryBrush}"
                                 IsVisible="{Binding Description.Length}" />
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
          <!-- Pinned checksum (hash-consent): a later update with a different hash re-prompts. -->
          <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding ConsentChecksum, Converter={x:Static ObjectConverters.IsNotNull}}">
            <TextBlock Grid.Column="0" Text="{Binding Loc[StoreConsentChecksum]}" FontSize="11"
                       Foreground="{DynamicResource SETextFaintBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Grid.Column="1" Text="{Binding ConsentChecksum}" FontSize="10.5" TextTrimming="CharacterEllipsis"
                       FontFamily="Cascadia Code,Menlo,Consolas,monospace" Foreground="{DynamicResource SETextSecondaryBrush}"
                       VerticalAlignment="Center" />
          </Grid>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Classes="Subtle" Content="{Binding Loc[Cancel]}" Command="{Binding CancelConsentCommand}" />
            <Button Classes="Accent" Content="{Binding Loc[StoreConsentApprove]}" Command="{Binding ConfirmConsentCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
