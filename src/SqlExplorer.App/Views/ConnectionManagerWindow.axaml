<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:SqlExplorer.App.Converters"
        xmlns:vm="using:SqlExplorer.App.ViewModels"
        x:Class="SqlExplorer.App.Views.ConnectionManagerWindow"
        Title="{Binding Loc[ManageConnections]}"
        Width="960" Height="640" MinWidth="720" MinHeight="460"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <!-- One row per ConnectionField, shared between the basic list and the Advanced expander
         (mirrors the retired ConnectionDialog). Bindings resolve against a ConnectionFieldInput. -->
    <DataTemplate x:Key="FieldTemplate">
      <StackPanel Spacing="2" Margin="0,4,0,0">
        <TextBlock Text="{Binding Label}" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
                   Text="{Binding Value}"
                   PlaceholderText="{Binding Watermark}"
                   PasswordChar="{Binding PasswordChar}"
                   IsVisible="{Binding IsText}" />
          <CheckBox Grid.Column="0"
                    IsChecked="{Binding BoolValue}"
                    IsVisible="{Binding IsBool}" />
          <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Choices}"
                    SelectedItem="{Binding Value}"
                    IsVisible="{Binding IsChoice}" />
          <Button Grid.Column="1" Margin="6,0,0,0"
                  Content="{Binding $parent[Window].DataContext.Loc[Browse]}"
                  IsVisible="{Binding IsFile}"
                  Click="OnBrowseClick" />
        </Grid>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Grid ColumnDefinitions="280,Auto,*">

    <!-- ============ Left: folder + connection tree ============ -->
    <Border Grid.Column="0" Background="{DynamicResource SEPanelBgBrush}"
            BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar: filter + add/duplicate/delete -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="8,8,8,6" >
          <TextBox Grid.Column="0" Text="{Binding Filter}"
                   PlaceholderText="{Binding Loc[FilterConnections]}" />
          <Button Grid.Column="1" Classes="Subtle" Margin="4,0,0,0" Padding="7,5"
                  ToolTip.Tip="{Binding Loc[NewConnection]}"
                  Command="{Binding NewConnectionCommand}">
            <Path Width="14" Height="14" Data="{x:Static vm:NodeIcons.Plus}"
                  Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.4"
                  StrokeJoin="Round" StrokeLineCap="Round" />
          </Button>
          <Button Grid.Column="2" Classes="Subtle" Padding="7,5"
                  ToolTip.Tip="{Binding Loc[NewFolder]}"
                  Command="{Binding NewFolderCommand}">
            <Path Width="14" Height="14" Data="{x:Static vm:NodeIcons.FolderPlus}"
                  Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.4"
                  StrokeJoin="Round" StrokeLineCap="Round" />
          </Button>
          <Button Grid.Column="3" Classes="Subtle" Padding="7,5"
                  ToolTip.Tip="{Binding Loc[DuplicateConnection]}"
                  Command="{Binding DuplicateConnectionCommand}">
            <Path Width="14" Height="14" Data="{x:Static vm:NodeIcons.Duplicate}"
                  Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.4"
                  StrokeJoin="Round" StrokeLineCap="Round" />
          </Button>
          <Button Grid.Column="4" Classes="Subtle" Padding="7,5"
                  ToolTip.Tip="{Binding Loc[Delete]}"
                  Command="{Binding DeleteConnectionCommand}">
            <Path Width="14" Height="14" Data="{x:Static vm:NodeIcons.Trash}"
                  Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.4"
                  StrokeJoin="Round" StrokeLineCap="Round" />
          </Button>
        </Grid>

        <TreeView Grid.Row="1" x:Name="ConnectionTree" Padding="4,0,4,4"
                  ItemsSource="{Binding Nodes}"
                  SelectedItem="{Binding SelectedNode}">
          <TreeView.Styles>
            <Style Selector="TreeViewItem">
              <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            </Style>
          </TreeView.Styles>
          <TreeView.ItemTemplate>
            <TreeDataTemplate ItemsSource="{Binding Children}">
              <!-- Background carries the drop-target highlight (see ConnectionManagerNode.DropBrush). -->
              <Border Background="{Binding DropBrush}" CornerRadius="3" Padding="2,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <!-- Connection colour flag (prod = red). -->
                  <Border Width="3" Height="14" CornerRadius="1.5" VerticalAlignment="Center"
                          Background="{Binding ColorBrush}" IsVisible="{Binding HasColor}" />
                  <Path Width="16" Height="16" VerticalAlignment="Center"
                        Data="{Binding Icon}"
                        Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.3"
                        StrokeJoin="Round" StrokeLineCap="Round" />
                  <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding ConnectionCount}" VerticalAlignment="Center"
                             FontSize="11" Foreground="{DynamicResource SETextFaintBrush}"
                             IsVisible="{Binding IsFolder}" />
                </StackPanel>
              </Border>
            </TreeDataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>

        <Border Grid.Row="2" BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,1,0,0"
                Padding="10,6">
          <TextBlock Text="{Binding Summary}" FontSize="11"
                     Foreground="{DynamicResource SETextFaintBrush}" />
        </Border>
      </Grid>
    </Border>

    <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns" Background="Transparent" />

    <!-- ============ Right: detail panes ============ -->
    <Panel Grid.Column="2">

      <!-- Empty state -->
      <TextBlock IsVisible="{Binding IsEmptyPane}"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Foreground="{DynamicResource SETextFaintBrush}"
                 Text="{Binding Loc[ManagerEmptyHint]}" />

      <!-- Folder detail -->
      <StackPanel IsVisible="{Binding IsFolderPane}" Margin="22" Spacing="4">
        <TextBlock Text="{Binding FolderName}" FontSize="15"
                   Foreground="{DynamicResource SETextPrimaryBrush}" Margin="0,0,0,10" />
        <TextBlock Text="{Binding Loc[FolderName]}" Foreground="{DynamicResource SETextSecondaryBrush}" />
        <TextBox Text="{Binding FolderName}" HorizontalAlignment="Stretch" />
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
          <Button Classes="Subtle" Content="{Binding Loc[DeleteFolder]}"
                  Foreground="{DynamicResource SEStatusErrorBrush}"
                  Command="{Binding DeleteFolderCommand}" />
          <Button Classes="Accent" Content="{Binding Loc[Save]}"
                  Command="{Binding RenameFolderCommand}" />
        </StackPanel>
        <TextBlock Text="{Binding Loc[FolderDeleteNote]}" TextWrapping="Wrap" MaxWidth="420"
                   HorizontalAlignment="Left" FontSize="11.5" Margin="0,18,0,0"
                   Foreground="{DynamicResource SETextFaintBrush}" />
      </StackPanel>

      <!-- Connection detail (reuses the ConnectionDialogViewModel form) -->
      <Grid IsVisible="{Binding IsConnectionPane}" RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" DataContext="{Binding Detail}">
          <StackPanel Margin="22,18" Spacing="10">

            <TextBlock Text="{Binding Loc[ConnectionName]}" />
            <TextBox Text="{Binding Name}" />

            <TextBlock Text="{Binding Loc[Folder]}" />
            <!-- Type-ahead over existing folder paths (from the manager VM), but free text is allowed so
                 a new path can be typed. -->
            <AutoCompleteBox Text="{Binding Folder, Mode=TwoWay}"
                             PlaceholderText="{Binding Loc[FolderHint]}"
                             ItemsSource="{Binding $parent[Window].DataContext.FolderSuggestions}"
                             FilterMode="Contains"
                             MinimumPrefixLength="0"
                             HorizontalAlignment="Stretch" />

            <TextBlock Text="{Binding Loc[Provider]}" />
            <ComboBox ItemsSource="{Binding AvailableProviders}"
                      SelectedItem="{Binding SelectedProvider}"
                      HorizontalAlignment="Stretch" />

            <!-- Import from a pasted connection string (FR-1); hidden for providers that can't parse one. -->
            <StackPanel Spacing="2" Margin="0,4,0,0" IsVisible="{Binding SupportsImport}">
              <TextBlock Text="{Binding Loc[ImportConnectionString]}" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding ImportConnectionString}"
                         PlaceholderText="{Binding Loc[ImportConnectionStringHint]}" />
                <Button Grid.Column="1" Margin="6,0,0,0" Content="{Binding Loc[Import]}"
                        Command="{Binding ImportFromConnectionStringCommand}" />
              </Grid>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding BasicFields}" ItemTemplate="{StaticResource FieldTemplate}" />

            <Expander Header="{Binding Loc[AdvancedSettings]}" IsVisible="{Binding HasAdvancedFields}"
                      IsExpanded="{Binding IsAdvancedExpanded}" Margin="0,4,0,0"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
              <StackPanel HorizontalAlignment="Stretch">
                <ContentControl Content="{Binding CustomAdvancedView}" IsVisible="{Binding HasCustomAdvancedView}" />
                <ItemsControl ItemsSource="{Binding AdvancedFields}" ItemTemplate="{StaticResource FieldTemplate}"
                              IsVisible="{Binding !HasCustomAdvancedView}" />
              </StackPanel>
            </Expander>

            <TextBlock Text="{Binding Loc[ConnectionColor]}" Margin="0,4,0,0" />
            <ItemsControl ItemsSource="{Binding ColorOptions}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Padding="0" Background="Transparent" BorderThickness="0"
                          Command="{Binding $parent[ItemsControl].DataContext.SelectColorCommand}"
                          CommandParameter="{Binding}">
                    <Panel Width="24" Height="24">
                      <Ellipse Width="20" Height="20"
                               Fill="{Binding Value, Converter={x:Static conv:HexBrushConverter.Instance}}"
                               Stroke="{DynamicResource SEHairlineBrush}" StrokeThickness="1" />
                      <Ellipse Width="24" Height="24" StrokeThickness="2"
                               Stroke="{DynamicResource SEAccentBrush}"
                               IsVisible="{Binding IsSelected}" />
                    </Panel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <CheckBox IsChecked="{Binding ReadOnly}" Content="{Binding Loc[ReadOnlyMode]}" Margin="0,4,0,0" />

            <!-- MCP (AI) access: opt-in per connection (default None = invisible to the AI). -->
            <TextBlock Text="{Binding Loc[AiAccess]}" FontWeight="SemiBold" Margin="0,12,0,0" />
            <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding AiAccessModes}"
                      SelectedItem="{Binding AiAccess}" />
            <TextBlock Text="{Binding Loc[AiAccessHint]}" FontSize="11" TextWrapping="Wrap"
                       Foreground="{DynamicResource SETextFaintBrush}" />

            <!-- Extra visible step before granting AI write access. -->
            <Border IsVisible="{Binding ShowAiWriteWarning}" Margin="0,2,0,0"
                    Background="#22D6A545" BorderBrush="#66D6A545" BorderThickness="1" CornerRadius="5" Padding="10,6">
              <TextBlock Text="{Binding Loc[AiWriteWarning]}" FontSize="12" Foreground="#E7C77A" TextWrapping="Wrap" />
            </Border>

            <CheckBox IsChecked="{Binding ExcludeFromMcp}" Content="{Binding Loc[ExcludeFromMcp]}" Margin="0,4,0,0" />
            <TextBlock Text="{Binding Loc[ExcludeFromMcpHint]}" FontSize="11" TextWrapping="Wrap"
                       Foreground="{DynamicResource SETextFaintBrush}" />
          </StackPanel>
        </ScrollViewer>

        <!-- Action bar: Test lives on the detail VM; Save/Duplicate/Delete/Discard are manager commands. -->
        <Border Grid.Row="1" Background="{DynamicResource SEToolbarBgBrush}"
                BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,1,0,0"
                Padding="16,10">
          <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
            <Button Grid.Column="0" Content="{Binding Loc[Test]}" Command="{Binding Detail.TestCommand}" />
            <TextBlock Grid.Column="1" Text="{Binding Detail.TestResult}" Margin="10,0,0,0"
                       VerticalAlignment="Center" FontSize="11.5"
                       Foreground="{DynamicResource SETextFaintBrush}" />
            <Button Grid.Column="3" Classes="Subtle" Content="{Binding Loc[DuplicateConnection]}"
                    Command="{Binding DuplicateConnectionCommand}"
                    IsVisible="{Binding CanActOnConnection}" Margin="0,0,8,0" />
            <Button Grid.Column="4" Classes="Subtle" Content="{Binding Loc[Delete]}"
                    Foreground="{DynamicResource SEStatusErrorBrush}"
                    Command="{Binding DeleteConnectionCommand}"
                    IsVisible="{Binding CanActOnConnection}" Margin="0,0,8,0" />
            <Button Grid.Column="5" Classes="Accent" Content="{Binding Loc[Save]}"
                    Command="{Binding SaveConnectionCommand}"
                    IsEnabled="{Binding Detail.CanSave}" IsDefault="True" />
          </Grid>
        </Border>
      </Grid>
    </Panel>
  </Grid>
</Window>
