<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SqlExplorer.App.Views.AlterObjectDialog"
        Title="{Binding DialogTitle}"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="10">

    <TextBlock Text="{Binding ObjectLabel}" FontWeight="SemiBold" FontSize="15" />

    <TextBlock Text="{Binding Loc[IrreversibleWarning]}" TextWrapping="Wrap"
               Foreground="{DynamicResource SEStatusErrorBrush}"
               IsVisible="{Binding IsDestructive}" />

    <!-- Add-column input: name + type + nullable. -->
    <StackPanel Spacing="4" IsVisible="{Binding IsAddColumn}">
      <TextBlock Text="{Binding Loc[ColumnName]}" />
      <TextBox Text="{Binding NewColumnName}" />
      <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
        <!-- Editable: the list is starting-point suggestions, not the only allowed values. -->
        <ComboBox Grid.Column="0" Margin="0,0,8,0" IsEditable="True"
                  ItemsSource="{Binding ColumnTypes}" Text="{Binding NewColumnType, Mode=TwoWay}"
                  HorizontalAlignment="Stretch" />
        <CheckBox Grid.Column="1" Content="{Binding Loc[ColumnNullable]}" IsChecked="{Binding NewColumnNullable}" />
      </Grid>
    </StackPanel>

    <!-- Rename-column input: new name (old name is shown via ObjectLabel above). -->
    <StackPanel Spacing="4" IsVisible="{Binding IsRenameColumn}">
      <TextBlock Text="{Binding Loc[NewName]}" />
      <TextBox Text="{Binding NewColumnName}" />
    </StackPanel>

    <TextBlock Text="{Binding Loc[SqlPreview]}" Margin="0,4,0,0" />
    <TextBox Text="{Binding SqlPreview}" AcceptsReturn="True" TextWrapping="Wrap"
             FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="12"
             Height="70" />

    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
      <Button Grid.Column="1" Classes="Subtle" Content="{Binding Loc[Cancel]}" Click="OnCancel" Margin="0,0,8,0" />
      <Button Grid.Column="2" Classes="Accent" Content="{Binding Loc[Confirm]}" Click="OnConfirm"
              IsEnabled="{Binding CanConfirm}" />
    </Grid>
  </StackPanel>
</Window>
