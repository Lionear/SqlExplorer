<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SqlExplorer.App.Views.CreateObjectDialog"
        Title="{Binding DialogTitle}"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="10">

    <TextBlock Text="{Binding Loc[ObjectName]}" />
    <TextBox Text="{Binding Name}" />

    <!-- Column grid: table creation only. Header and row columns share the same fixed widths (60/40/40/28
         for Nullable/PK/AI/remove) so the two independent Grids line up — Auto-width columns size to
         each Grid's own content and drift apart between a text header and a checkbox row. -->
    <StackPanel Spacing="4" IsVisible="{Binding IsTable}">
      <Grid ColumnDefinitions="*,110,60,40,40,28" Margin="0,4,0,0">
        <TextBlock Grid.Column="0" Text="{Binding Loc[ColumnName]}" FontSize="11"
                   Foreground="{DynamicResource SETextFaintBrush}" />
        <TextBlock Grid.Column="1" Text="{Binding Loc[ColumnType]}" FontSize="11"
                   Foreground="{DynamicResource SETextFaintBrush}" />
        <TextBlock Grid.Column="2" Text="{Binding Loc[ColumnNullable]}" FontSize="11"
                   HorizontalAlignment="Center" TextAlignment="Center"
                   Foreground="{DynamicResource SETextFaintBrush}" />
        <TextBlock Grid.Column="3" Text="{Binding Loc[ColumnPrimaryKey]}" FontSize="11"
                   HorizontalAlignment="Center" TextAlignment="Center"
                   Foreground="{DynamicResource SETextFaintBrush}"
                   ToolTip.Tip="{Binding Loc[PrimaryKeyHint]}" />
        <TextBlock Grid.Column="4" Text="{Binding Loc[ColumnAutoIncrement]}" FontSize="11"
                   HorizontalAlignment="Center" TextAlignment="Center"
                   Foreground="{DynamicResource SETextFaintBrush}"
                   ToolTip.Tip="{Binding Loc[AutoIncrementHint]}" />
      </Grid>
      <ItemsControl ItemsSource="{Binding Columns}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="*,110,60,40,40,28" Margin="0,2">
              <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding Name}" />
              <!-- Editable: the list is starting-point suggestions, not the only allowed values —
                   e.g. pick "varchar(255)" then edit the length, or type "int unsigned" freely. -->
              <ComboBox Grid.Column="1" Margin="0,0,4,0" IsEditable="True"
                        ItemsSource="{Binding $parent[ItemsControl].DataContext.ColumnTypes}"
                        Text="{Binding Type, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              <CheckBox Grid.Column="2" HorizontalAlignment="Center" IsChecked="{Binding Nullable}" />
              <CheckBox Grid.Column="3" HorizontalAlignment="Center" IsChecked="{Binding PrimaryKey}"
                        ToolTip.Tip="{Binding $parent[ItemsControl].DataContext.Loc[PrimaryKeyHint]}" />
              <CheckBox Grid.Column="4" HorizontalAlignment="Center" IsChecked="{Binding AutoIncrement}"
                        ToolTip.Tip="{Binding $parent[ItemsControl].DataContext.Loc[AutoIncrementHint]}" />
              <Button Grid.Column="5" Classes="Subtle" Content="×" Padding="0" HorizontalAlignment="Center"
                      Command="{Binding $parent[ItemsControl].DataContext.RemoveColumnCommand}"
                      CommandParameter="{Binding}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <Button Classes="Subtle" Content="{Binding Loc[AddColumn]}" Command="{Binding AddColumnCommand}"
              HorizontalAlignment="Left" />
    </StackPanel>

    <TextBlock Text="{Binding Loc[SqlPreview]}" Margin="0,4,0,0" />
    <TextBox Text="{Binding SqlPreview}" AcceptsReturn="True" TextWrapping="Wrap"
             FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="12"
             Height="90" />

    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
      <Button Grid.Column="1" Classes="Subtle" Content="{Binding Loc[Cancel]}" Click="OnCancel" Margin="0,0,8,0" />
      <Button Grid.Column="2" Classes="Accent" Content="{Binding Loc[Create]}" Click="OnCreate"
              IsEnabled="{Binding CanSave}" IsDefault="True" />
    </Grid>
  </StackPanel>
</Window>
