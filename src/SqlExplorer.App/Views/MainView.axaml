<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:cvt="using:SqlExplorer.App.Converters"
             xmlns:vm="using:SqlExplorer.App.ViewModels"
             xmlns:views="using:SqlExplorer.App.Views"
             x:Class="SqlExplorer.App.Views.MainView">
  <UserControl.Resources>
    <!-- Recursive menu-item theme for the tools tree (ToolMenuNode): a leaf binds its Run command; a
         group re-applies this same theme to its Children, giving arbitrarily deep submenus. -->
    <ControlTheme x:Key="ToolMenuNodeTheme" TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
      <Setter Property="Header" Value="{Binding Title}" />
      <Setter Property="Command" Value="{Binding Run}" />
      <Setter Property="ItemsSource" Value="{Binding Children}" />
      <!-- DynamicResource (not Static): a ControlTheme can't reference itself via StaticResource during
           construction; DynamicResource resolves lazily once the dictionary is built. -->
      <Setter Property="ItemContainerTheme" Value="{DynamicResource ToolMenuNodeTheme}" />
    </ControlTheme>
  </UserControl.Resources>
  <UserControl.Styles>
    <!-- "Go to object" reads as a search-field, not a button — muted background + hover border only. -->
    <Style Selector="Button.Search">
      <Setter Property="Background" Value="{DynamicResource SESecondaryBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SEHairlineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="{DynamicResource SETextFaintBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.Search:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SESecondaryBgBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource SETextFaintBrush}" />
    </Style>
    <!-- Document tab-strip: 16px vector icon in front of the title. -->
    <Style Selector="Path.TabIcon">
      <Setter Property="Width" Value="14" />
      <Setter Property="Height" Value="14" />
      <Setter Property="Stroke" Value="{DynamicResource SETextSecondaryBrush}" />
      <Setter Property="StrokeThickness" Value="1.3" />
      <Setter Property="StrokeJoin" Value="Round" />
      <Setter Property="StrokeLineCap" Value="Round" />
    </Style>

    <!-- Right-hand tool-window stripe buttons (SE-123): icon + vertical label, selection-filled when
         the panel is open. JetBrains-style. -->
    <Style Selector="Button.Stripe">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="4,8" />
      <Setter Property="Margin" Value="3,0,3,4" />
      <Setter Property="Foreground" Value="{DynamicResource SETextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.Stripe:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SEHoverBgBrush}" />
      <Setter Property="TextElement.Foreground" Value="{DynamicResource SETextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.Stripe.on">
      <Setter Property="Background" Value="{DynamicResource SESelectionBgBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource SETextPrimaryBrush}" />
    </Style>

    <!-- Status-bar toggles for Edge.Bottom tool-windows: compact pill, selection-filled when open. -->
    <Style Selector="Button.StatusToggle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource SETextSecondaryBrush}" />
    </Style>
    <Style Selector="Button.StatusToggle:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SEHoverBgBrush}" />
      <Setter Property="TextElement.Foreground" Value="{DynamicResource SETextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.StatusToggle.on">
      <Setter Property="Background" Value="{DynamicResource SESelectionBgBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource SETextPrimaryBrush}" />
    </Style>
  </UserControl.Styles>
  <!-- Row 2 = splitter for the bottom tool-window, row 3 = the panel itself (its height is restored
       and persisted in code-behind, same as the sidebar width), row 4 = status bar. -->
  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="170" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <!-- App update available banner (blue) — SE-137 startup check found a newer build on the channel. -->
      <Border IsVisible="{Binding Update.HasUpdate}" Background="#1F3B82F6"
              BorderBrush="#593B82F6" BorderThickness="0,0,0,1" Padding="12,7">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding Update.BannerText}" Foreground="{DynamicResource SEAccentBrush}"
                     FontSize="12" VerticalAlignment="Center" />
          <Button Classes="Subtle" Content="{Binding Loc[UpdateBannerViewChangelog]}"
                  Command="{Binding Update.ViewChangelogCommand}" />
          <Button Classes="Subtle" Content="{Binding Loc[UpdateBannerLater]}"
                  Command="{Binding Update.LaterCommand}" />
        </StackPanel>
      </Border>

      <!-- Plugin "restart needed" banner (amber) — shown when the Store staged install/enable/remove changes. -->
      <Border IsVisible="{Binding PluginRestartRequired}" Background="#1FE0A33E"
              BorderBrush="#59E0A33E" BorderThickness="0,0,0,1" Padding="12,7">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding Loc[MainPluginRestartBanner]}" Foreground="{DynamicResource SEStatusWaitingBrush}"
                     FontSize="12" VerticalAlignment="Center" />
          <Button Classes="Subtle" Content="{Binding Loc[MainRestartNow]}" Command="{Binding RestartAppCommand}" />
        </StackPanel>
      </Border>

      <!-- Top toolbar (SE-123): back to two items. History and Output moved to the toggle on the edge
           where their panel lives (right stripe / status bar). "Go to object" reads as a search-field
           with a ⌘K hint — it IS a quick-open, not an action. -->
      <Border Background="{DynamicResource SEToolbarBgBrush}"
              BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,6">
          <Button Classes="Accent"
                  Command="{Binding NewQueryTabCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <Path Width="12" Height="12" Stretch="Uniform" Data="{x:Static vm:NodeIcons.Plus}"
                    Stroke="{DynamicResource SEAccentFgBrush}" StrokeThickness="1.4"
                    StrokeJoin="Round" StrokeLineCap="Round" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Loc[NewQueryTab]}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Classes="Search" Padding="9,5" MinWidth="280" ToolTip.Tip="Ctrl+K"
                  Command="{Binding ToggleSearchCommand}">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Path Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center"
                    Data="M7,3 A4,4 0 1 0 7,11 A4,4 0 1 0 7,3 M10,10 L13.5,13.5"
                    Stroke="{DynamicResource SETextFaintBrush}" StrokeThickness="1.3"
                    StrokeJoin="Round" StrokeLineCap="Round" />
              <TextBlock Grid.Column="1" Margin="7,0,0,0" VerticalAlignment="Center"
                         Text="{Binding Loc[GoToObject]}" FontSize="12.5"
                         Foreground="{DynamicResource SETextFaintBrush}" />
              <Border Grid.Column="2" Padding="4,1" CornerRadius="3"
                      BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1"
                      VerticalAlignment="Center">
                <TextBlock Text="⌘K" FontSize="10.5" FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                           Foreground="{DynamicResource SETextFaintBrush}" />
              </Border>
            </Grid>
          </Button>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- Body: connection sidebar | editor tabs | (optional) history panel -->
    <Grid Grid.Row="1" x:Name="BodyGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" MinWidth="180" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <!-- History tool-window: splitter + panel + the right-hand stripe holding its toggle.
             The panel column's width is restored/persisted in code-behind (same as the sidebar). -->
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="300" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Left sidebar: one unified tree (DBeaver-style), loaded lazily on expand. -->
      <Border Grid.Column="0" Background="{DynamicResource SEPanelBgBrush}">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="10,8,8,6">
            <TextBlock Grid.Column="0" Text="{Binding Loc[Connections]}"
                       FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource SETextSecondaryBrush}" VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="Accent" Padding="8,4"
                    ToolTip.Tip="{Binding Loc[NewConnection]}"
                    Command="{Binding NewConnectionCommand}">
              <Path Width="12" Height="12" Stretch="Uniform" Data="{x:Static vm:NodeIcons.Plus}"
                    Stroke="{DynamicResource SEAccentFgBrush}" StrokeThickness="1.5"
                    StrokeJoin="Round" StrokeLineCap="Round" />
            </Button>
          </Grid>

          <TreeView Grid.Row="1"
                    x:Name="SchemaTree"
                    Padding="4,0,4,4"
                    ItemsSource="{Binding ConnectionNodes}"
                    SelectedItem="{Binding SelectedNode}">
            <TreeView.Styles>
              <Style Selector="TreeViewItem">
                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                <!-- Stretch the row so the right-aligned size badge reaches the tree's right edge. -->
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <!-- Compact rows (the Fluent default is roomy): tighter height + padding. -->
                <Setter Property="MinHeight" Value="22" />
                <Setter Property="Padding" Value="4,1" />
              </Style>
            </TreeView.Styles>
            <TreeView.ContextMenu>
              <ContextMenu>
                <MenuItem Header="{Binding Loc[Connect]}" Command="{Binding ConnectCommand}"
                          IsVisible="{Binding SelectedNode.CanConnect, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[Disconnect]}" Command="{Binding DisconnectCommand}"
                          IsVisible="{Binding SelectedNode.CanDisconnect, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[TestConnection]}" Command="{Binding TestConnectionCommand}"
                          IsVisible="{Binding SelectedNode.IsConnectionNode, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[EditConnection]}" Command="{Binding EditConnectionCommand}"
                          IsVisible="{Binding SelectedNode.IsConnectionNode, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[DuplicateConnection]}" Command="{Binding DuplicateConnectionCommand}"
                          IsVisible="{Binding SelectedNode.IsConnectionNode, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[Delete]}" Command="{Binding DeleteConnectionCommand}"
                          IsVisible="{Binding SelectedNode.IsConnectionNode, FallbackValue=False}" />
                <!-- Tool plugins applicable to the selected node (universal backup, dumps, …). The
                     ItemContainerTheme is self-referencing (binds ItemsSource to each node's Children and
                     re-applies itself), so a tool's MenuPath renders as arbitrarily deep submenus. -->
                <MenuItem Header="{Binding Loc[Tools]}" ItemsSource="{Binding ApplicableTools}"
                          IsVisible="{Binding HasApplicableTools}"
                          ItemContainerTheme="{DynamicResource ToolMenuNodeTheme}" />
                <MenuItem Header="{Binding Loc[Refresh]}" Command="{Binding RefreshNodeCommand}"
                          IsVisible="{Binding SelectedNode.CanRefresh, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[CollapseAll]}" Command="{Binding CollapseAllNodeCommand}"
                          IsVisible="{Binding SelectedNode.CanCollapseAll, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[NewDatabase]}" Command="{Binding NewDatabaseCommand}"
                          IsVisible="{Binding SelectedNode.CanCreateDatabase, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[NewSchema]}" Command="{Binding NewSchemaCommand}"
                          IsVisible="{Binding SelectedNode.CanCreateSchema, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[NewTable]}" Command="{Binding NewTableCommand}"
                          IsVisible="{Binding SelectedNode.CanCreateTable, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[NewUser]}" Command="{Binding NewUserCommand}"
                          IsVisible="{Binding SelectedNode.CanManageUsers, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[DeleteUser]}" Command="{Binding DeleteUserCommand}"
                          IsVisible="{Binding SelectedNode.CanDeleteUser, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[NewLogin]}" Command="{Binding NewLoginCommand}"
                          IsVisible="{Binding SelectedNode.CanManageLogins, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[LoginProperties]}" Command="{Binding LoginPropertiesCommand}"
                          IsVisible="{Binding SelectedNode.CanManageLogin, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[DropLogin]}" Command="{Binding DropLoginCommand}"
                          IsVisible="{Binding SelectedNode.CanManageLogin, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[AddColumnMenu]}" Command="{Binding AddColumnCommand}"
                          IsVisible="{Binding SelectedNode.CanAddColumn, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[ImportCsv]}" Command="{Binding ImportCsvCommand}"
                          IsVisible="{Binding SelectedNode.CanImportCsv, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[BrowseTable]}" Command="{Binding BrowseTableCommand}"
                          IsVisible="{Binding SelectedNode.IsTableOrView, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[SelectTop1000]}" Command="{Binding GenerateSqlCommand}" CommandParameter="SelectTop"
                          IsVisible="{Binding SelectedNode.IsTableOrView, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[Export]}" Command="{Binding ExportTableCommand}"
                          IsVisible="{Binding SelectedNode.IsTableOrView, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[SqlCommands]}"
                          IsVisible="{Binding SelectedNode.CanGenerateSqlCommands, FallbackValue=False}">
                  <MenuItem Header="SELECT *" Command="{Binding GenerateSqlCommand}" CommandParameter="Select" />
                  <MenuItem Header="SELECT columns" Command="{Binding GenerateSqlCommand}" CommandParameter="SelectColumns" />
                  <MenuItem Header="INSERT" Command="{Binding GenerateSqlCommand}" CommandParameter="Insert" />
                  <MenuItem Header="UPDATE" Command="{Binding GenerateSqlCommand}" CommandParameter="Update" />
                  <MenuItem Header="DELETE" Command="{Binding GenerateSqlCommand}" CommandParameter="Delete" />
                  <MenuItem Header="COUNT(*)" Command="{Binding GenerateSqlCommand}" CommandParameter="Count" />
                </MenuItem>
                <MenuItem Header="{Binding Loc[ViewDefinition]}" Command="{Binding ViewDefinitionCommand}"
                          IsVisible="{Binding SelectedNode.CanViewDefinition, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[ExecuteRoutine]}" Command="{Binding ExecuteRoutineCommand}"
                          IsVisible="{Binding SelectedNode.CanExecuteRoutine, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[CopyName]}" Command="{Binding CopyNameCommand}"
                          IsVisible="{Binding SelectedNode.IsCopyable, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[CopyQualifiedName]}" Command="{Binding CopyQualifiedNameCommand}"
                          IsVisible="{Binding SelectedNode.IsTableOrView, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[RenameColumn]}" Command="{Binding RenameColumnCommand}"
                          IsVisible="{Binding SelectedNode.CanRenameColumn, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[DropColumn]}" Command="{Binding DropColumnCommand}"
                          IsVisible="{Binding SelectedNode.CanDropColumn, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[TruncateTable]}" Command="{Binding TruncateTableCommand}"
                          IsVisible="{Binding SelectedNode.CanTruncate, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[DropTable]}" Command="{Binding DropTableCommand}"
                          IsVisible="{Binding SelectedNode.CanDropTable, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[DropSchema]}" Command="{Binding DropSchemaCommand}"
                          IsVisible="{Binding SelectedNode.CanDropSchema, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[DropDatabase]}" Command="{Binding DropDatabaseCommand}"
                          IsVisible="{Binding SelectedNode.CanDropDatabase, FallbackValue=False}" />
                <Separator IsVisible="{Binding SelectedNode.CanShowProperties, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[Properties]}" Command="{Binding ShowPropertiesCommand}"
                          IsVisible="{Binding SelectedNode.CanShowProperties, FallbackValue=False}" />
                <Separator IsVisible="{Binding SelectedNode.CanShowActivityMonitor, FallbackValue=False}" />
                <MenuItem Header="{Binding Loc[ActivityMonitor]}" Command="{Binding ActivityMonitorCommand}"
                          IsVisible="{Binding SelectedNode.CanShowActivityMonitor, FallbackValue=False}" />
              </ContextMenu>
            </TreeView.ContextMenu>
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}">
                <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch" ToolTip.Tip="{Binding Tooltip}">
                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <!-- Connection colour flag (prod = red): a coloured bar on the root when set. -->
                    <Border Width="3" Height="14" CornerRadius="1.5" VerticalAlignment="Center"
                            Background="{Binding ConnectionColorBrush}"
                            IsVisible="{Binding HasConnectionColor}" />
                    <!-- Connection state LED (connection roots only): grey/blue/green/red. -->
                    <Panel Width="8" Height="8" VerticalAlignment="Center" IsVisible="{Binding IsConnectionNode}">
                      <Ellipse Width="8" Height="8"
                               Fill="{Binding State, Converter={x:Static cvt:ConnectionStateBrushConverter.Instance}}" />
                    </Panel>
                    <Image Width="16" Height="16" VerticalAlignment="Center"
                           RenderOptions.BitmapInterpolationMode="HighQuality"
                           Source="{Binding IconImage}" IsVisible="{Binding HasImageIcon}" />
                    <Path Width="16" Height="16" VerticalAlignment="Center"
                          Data="{Binding IconGeometry}"
                          Stroke="{DynamicResource SETextSecondaryBrush}" StrokeThickness="1.3"
                          StrokeJoin="Round" StrokeLineCap="Round"
                          IsVisible="{Binding HasVectorIcon}" />
                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                  </StackPanel>
                  <!-- Right-aligned on-disk size badge (databases/tables), DataGrip-style. -->
                  <Border Grid.Column="1" IsVisible="{Binding HasBadge}" VerticalAlignment="Center"
                          Background="{DynamicResource SEHairlineBrush}" CornerRadius="3"
                          Padding="5,1" Margin="8,0,4,0">
                    <TextBlock Text="{Binding Badge}" FontSize="10.5"
                               Foreground="{DynamicResource SETextSecondaryBrush}" />
                  </Border>
                </Grid>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" Width="3" ResizeDirection="Columns" />

      <!-- Right: editor tabs (query panes + table-browse panes). Failures no longer show an inline
           banner here — every outcome (errors and successes alike) surfaces in the Output panel below. -->
      <Grid Grid.Column="2" Margin="0">

        <Panel>
        <TabControl x:Name="DocumentTabs" ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument}">
          <TabControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" ToolTip.Tip="{Binding TabTooltip}">
                <StackPanel.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="{Binding $parent[TabControl].DataContext.Loc[DuplicateTab]}"
                              Command="{Binding $parent[TabControl].DataContext.DuplicateTabCommand}"
                              CommandParameter="{Binding}" />
                    <Separator />
                    <MenuItem Header="{Binding $parent[TabControl].DataContext.Loc[CloseTab]}"
                              Command="{Binding $parent[TabControl].DataContext.CloseTabCommand}"
                              CommandParameter="{Binding}" />
                    <MenuItem Header="{Binding $parent[TabControl].DataContext.Loc[CloseOtherTabs]}"
                              Command="{Binding $parent[TabControl].DataContext.CloseOtherTabsCommand}"
                              CommandParameter="{Binding}" />
                    <MenuItem Header="{Binding $parent[TabControl].DataContext.Loc[CloseAllTabs]}"
                              Command="{Binding $parent[TabControl].DataContext.CloseAllTabsCommand}" />
                  </ContextMenu>
                </StackPanel.ContextMenu>
                <Path Classes="TabIcon" Data="{Binding TabIcon}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                <Button Content="×" Classes="Subtle" Padding="6,0" FontSize="15"
                        VerticalAlignment="Center"
                        Command="{Binding $parent[TabControl].DataContext.CloseTabCommand}"
                        CommandParameter="{Binding}" />
              </StackPanel>
            </DataTemplate>
          </TabControl.ItemTemplate>
          <TabControl.ContentTemplate>
            <DataTemplate>
              <views:DocumentView Margin="10" />
            </DataTemplate>
          </TabControl.ContentTemplate>
        </TabControl>

        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource SETextFaintBrush}"
                   Text="{Binding Loc[EmptyHint]}"
                   IsVisible="{Binding SelectedDocument, Converter={x:Static conv:ObjectConverters.IsNull}}" />
        </Panel>
      </Grid>

      <!-- History tool-window (Edge.Right): splitter, then the panel, then the stripe with its toggle. -->
      <GridSplitter Grid.Column="3" Width="3" ResizeDirection="Columns"
                    IsVisible="{Binding HistoryWindow.IsVisible}" />

      <Border Grid.Column="4" IsVisible="{Binding HistoryWindow.IsVisible}"
              Background="{DynamicResource SEPanelBgBrush}">
        <Grid RowDefinitions="Auto,Auto,*">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="10,8,8,6">
            <TextBlock Grid.Column="0" Text="{Binding Loc[History]}" FontWeight="SemiBold" FontSize="12"
                       Foreground="{DynamicResource SETextSecondaryBrush}" VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="Subtle" Padding="8,2"
                    Content="{Binding Loc[ClearHistory]}" Command="{Binding ClearHistoryCommand}" />
          </Grid>
          <TextBox Grid.Row="1" Margin="10,0,10,6" Text="{Binding HistorySearch}"
                   PlaceholderText="{Binding Loc[SearchHistory]}" />
          <ListBox Grid.Row="2" x:Name="HistoryList" Background="Transparent"
                   ItemsSource="{Binding HistoryEntries}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="1" Margin="0,2">
                  <Grid ColumnDefinitions="Auto,*">
                    <!-- AI badge: this entry was run by an AI client over MCP. -->
                    <Border Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Center"
                            Background="#223574F0" CornerRadius="4" Padding="4,0"
                            IsVisible="{Binding Source, Converter={x:Static cvt:EqualsConverter.Instance}, ConverterParameter=Ai}">
                      <TextBlock Text="AI" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource SEAccentBrush}" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding Sql}" TextWrapping="Wrap" MaxLines="2"
                               TextTrimming="CharacterEllipsis" FontSize="12"
                               FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
                  </Grid>
                  <TextBlock FontSize="10" Foreground="{DynamicResource SETextFaintBrush}">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0} · {1} rows · {2} ms">
                        <Binding Path="ConnectionName" />
                        <Binding Path="RowCount" />
                        <Binding Path="DurationMs" />
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Right-hand tool-window stripe (SE-123): one vertical button per Edge.Right panel. Its toggle
           sits on the same edge the panel opens on — that's the whole point of the redesign. Bound to
           ToolWindows so a third right-docked panel needs no XAML here. -->
      <Border Grid.Column="5" Background="{DynamicResource SEPanelBgBrush}"
              BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1,0,0,0">
        <ItemsControl ItemsSource="{Binding ToolWindows}" Margin="0,8,0,0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Classes="Stripe" Classes.on="{Binding IsVisible}"
                      IsVisible="{Binding Edge, Converter={x:Static cvt:EqualsConverter.Instance}, ConverterParameter={x:Static vm:ToolWindowEdge.Right}}"
                      Command="{Binding $parent[ItemsControl].DataContext.ToggleToolWindowCommand}"
                      CommandParameter="{Binding}">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                  <Path Width="15" Height="15" Stretch="Uniform" Data="{Binding Icon}"
                        Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1.3"
                        StrokeJoin="Round" StrokeLineCap="Round" HorizontalAlignment="Center" />
                  <!-- LayoutTransformControl (not RenderTransform): rotation must affect layout so the
                       stripe reserves the rotated text's height instead of overlapping the next button. -->
                  <LayoutTransformControl HorizontalAlignment="Center">
                    <LayoutTransformControl.LayoutTransform>
                      <RotateTransform Angle="90" />
                    </LayoutTransformControl.LayoutTransform>
                    <TextBlock Text="{Binding Title}" FontSize="11.5" />
                  </LayoutTransformControl>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </Grid>

    <!-- Quick-open overlay (Ctrl+K / toolbar button): fuzzy search tables/views/columns across every
         connected connection's cached schema snapshot, mixed with global app commands (New Query,
         Export, …) on the same ranked list. Enter/double-click opens a browse tab or runs the command,
         Escape closes. -->
    <Border Grid.Row="1" IsVisible="{Binding IsSearchVisible}"
            Background="#80000000">
      <Border Width="480" MaxHeight="420" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0"
              Background="{DynamicResource SEPanelBgBrush}"
              BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1" CornerRadius="6">
        <Grid RowDefinitions="Auto,*" Margin="10">
          <TextBox Grid.Row="0" x:Name="SearchBox" Text="{Binding SearchText}"
                    PlaceholderText="{Binding Loc[SearchObjects]}" />
          <ListBox Grid.Row="1" x:Name="SearchResultsList" Margin="0,6,0,0" MaxHeight="360"
                    Background="Transparent"
                    ItemsSource="{Binding SearchResults}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="1" Margin="0,2">
                  <TextBlock Text="{Binding Display}" FontSize="13" />
                  <TextBlock Text="{Binding Subtitle}" FontSize="10"
                             Foreground="{DynamicResource SETextFaintBrush}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Border>

    <!-- Output tool-window (Edge.Bottom): timestamped connection results + errors. Its toggle lives in
         the status bar right below; the splitter sits on the row above. -->
    <GridSplitter Grid.Row="2" Height="3" ResizeDirection="Rows"
                  IsVisible="{Binding OutputWindow.IsVisible}" />

    <Border Grid.Row="3" IsVisible="{Binding OutputWindow.IsVisible}"
            Background="{DynamicResource SEPanelBgBrush}">
      <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="10,6,8,4">
          <TextBlock Grid.Column="0" Text="{Binding Loc[Output]}" FontWeight="SemiBold" FontSize="12"
                     Foreground="{DynamicResource SETextSecondaryBrush}" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="Subtle" Padding="8,2"
                  Content="{Binding Loc[ClearOutput]}" Command="{Binding ClearOutputCommand}" />
        </Grid>
        <ListBox Grid.Row="1" x:Name="OutputList" Background="Transparent" ItemsSource="{Binding OutputEntries}">
          <ListBox.ContextMenu>
            <ContextMenu>
              <MenuItem Header="{Binding Loc[Copy]}" Command="{Binding CopyOutputEntryCommand}"
                        CommandParameter="{Binding #OutputList.SelectedItem}" />
              <MenuItem Header="{Binding Loc[CopyAll]}" Command="{Binding CopyAllOutputCommand}" />
            </ContextMenu>
          </ListBox.ContextMenu>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="Auto,Auto,Auto,*" Margin="0,1">
                <TextBlock Grid.Column="0" Text="{Binding TimeText}" FontSize="11"
                           FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                           Foreground="{DynamicResource SETextFaintBrush}" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Text="{Binding LevelText}" FontSize="11" FontWeight="SemiBold"
                           Width="44" Margin="0,0,8,0"
                           Foreground="{Binding IsError, Converter={x:Static cvt:OutputLevelBrushConverter.Instance}}" />
                <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="11" Margin="0,0,8,0"
                           Foreground="{DynamicResource SETextSecondaryBrush}" />
                <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="11" TextWrapping="Wrap"
                           FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <!-- Bottom status bar (SE-123): connection state on the left, the Edge.Bottom tool-window toggles
         next to it (so the toggle sits on the edge its panel opens on), run stats on the right. -->
    <Border Grid.Row="4" Background="{DynamicResource SEToolbarBgBrush}"
            BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="10,3">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                   Fill="{DynamicResource SEStatusConnectedBrush}"
                   IsVisible="{Binding SelectedConnection, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
          <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                   Fill="{DynamicResource SETextFaintBrush}"
                   IsVisible="{Binding SelectedConnection, Converter={x:Static conv:ObjectConverters.IsNull}}" />
          <TextBlock VerticalAlignment="Center" FontSize="12"
                     Foreground="{DynamicResource SETextSecondaryBrush}"
                     Text="{Binding SelectedConnection.Name, FallbackValue={x:Null}, TargetNullValue=—}" />
        </StackPanel>

        <!-- Bottom-edge tool-window toggles. Bound to ToolWindows, so a second bottom panel (Query Log,
             …) shows up here without touching this XAML. -->
        <ItemsControl Grid.Column="1" ItemsSource="{Binding ToolWindows}" Margin="14,0,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="4" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Classes="StatusToggle" Classes.on="{Binding IsVisible}"
                      IsVisible="{Binding Edge, Converter={x:Static cvt:EqualsConverter.Instance}, ConverterParameter={x:Static vm:ToolWindowEdge.Bottom}}"
                      Command="{Binding $parent[ItemsControl].DataContext.ToggleToolWindowCommand}"
                      CommandParameter="{Binding}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Path Width="14" Height="14" Stretch="Uniform" Data="{Binding Icon}"
                        Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="1.3"
                        StrokeJoin="Round" StrokeLineCap="Round" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                  <!-- Red error-count badge: a failure stays visible even with the panel collapsed. -->
                  <Border IsVisible="{Binding HasBadge}" Background="{DynamicResource SEStatusErrorBrush}"
                          CornerRadius="8" MinWidth="15" Height="15" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Badge}" FontSize="9.5" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,0" />
                  </Border>
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Run stats for the active document: rows · duration · engine. -->
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center"
                    IsVisible="{Binding SelectedDocument, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
          <TextBlock FontSize="12" Foreground="{DynamicResource SETextSecondaryBrush}"
                     Text="{Binding SelectedDocument.StatusLine}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
