<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SqlExplorer.App.Views.ToolDialog"
        Title="{Binding Title}"
        Width="520" Height="640" MinWidth="420" MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <!-- One row per ToolField (Route A) — same look as the connection dialog fields. -->
    <DataTemplate x:Key="ToolFieldTemplate">
      <StackPanel Spacing="2" Margin="0,4,0,0">
        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource SETextSecondaryBrush}" FontSize="11.5" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" Text="{Binding Value}"
                   PlaceholderText="{Binding Watermark}"
                   PasswordChar="{Binding PasswordChar}"
                   IsVisible="{Binding IsText}" />
          <CheckBox Grid.Column="0" IsChecked="{Binding BoolValue}" IsVisible="{Binding IsBool}" />
          <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" ItemsSource="{Binding Choices}"
                    SelectedItem="{Binding Value}" IsVisible="{Binding IsChoice}" />
          <!-- Password reveal toggle (eye). Vector Path, not an emoji glyph: Linux/Avalonia 12 has no
               colour-emoji fallback, so "👁" renders as a blank box. -->
          <ToggleButton Grid.Column="1" Margin="6,0,0,0" Padding="7,4"
                        IsChecked="{Binding RevealPassword}" IsVisible="{Binding IsPassword}">
            <Path Width="16" Height="16" Stretch="Uniform"
                  Fill="{DynamicResource SETextSecondaryBrush}"
                  Data="M1.7,8 C3.2,4.8 5.8,3.2 8,3.2 C10.2,3.2 12.8,4.8 14.3,8 C12.8,11.2 10.2,12.8 8,12.8 C5.8,12.8 3.2,11.2 1.7,8 Z M6,8 A2,2 0 1 0 10,8 A2,2 0 1 0 6,8 Z" />
          </ToggleButton>
          <!-- File browse (save or open per the field). -->
          <Button Grid.Column="1" Margin="6,0,0,0"
                  Content="{Binding $parent[Window].DataContext.Loc[Browse]}"
                  IsVisible="{Binding IsFile}" Click="OnBrowseClick" />
        </Grid>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Grid RowDefinitions="*,Auto,Auto,Auto">

    <!-- Row 0 fills the available height. Route A fields scroll if they overflow; a Route B custom view is
         given the full height directly (not inside a ScrollViewer) so it can grow with the window and manage
         its own scrolling (e.g. the backup object tree). Only one of the two is ever visible. -->
    <Panel Grid.Row="0">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasFields}">
        <StackPanel Margin="18,16" Spacing="8">
          <ItemsControl ItemsSource="{Binding Fields}" ItemTemplate="{StaticResource ToolFieldTemplate}"
                        IsEnabled="{Binding InputsEnabled}" />
          <Border IsVisible="{Binding HasPreview}" Margin="0,6,0,0" Padding="10,8"
                  Background="{DynamicResource SEPanelBgBrush}"
                  BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1" CornerRadius="4">
            <TextBlock Text="{Binding Preview}" TextWrapping="Wrap" FontSize="11.5"
                       FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                       Foreground="{DynamicResource SETextSecondaryBrush}" />
          </Border>
        </StackPanel>
      </ScrollViewer>

      <ContentControl Content="{Binding CustomView}" IsVisible="{Binding HasCustomView}"
                      IsEnabled="{Binding InputsEnabled}" Margin="18,16"
                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
    </Panel>

    <StackPanel Grid.Row="1" Spacing="8">
      <!-- Live per-item checklist (object-selection backup/restore); hidden for tools that don't report items. -->
      <Border Margin="18,8,18,0" MaxHeight="180" IsVisible="{Binding HasChecklist}"
              BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1"
              CornerRadius="4" Background="{DynamicResource SEPanelBgBrush}">
        <ItemsControl ItemsSource="{Binding Checklist}" Margin="4">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="18,*" Margin="4,2">
                <TextBlock Grid.Column="0" Text="{Binding StatusGlyph}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="12" TextWrapping="Wrap" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <!-- Progress / log — hidden until a run produces output, so it never shows as a big empty box. -->
      <Border Margin="18,0,18,0" MaxHeight="200" IsVisible="{Binding HasLogArea}"
              BorderBrush="{DynamicResource SEHairlineBrush}" BorderThickness="1"
              CornerRadius="4" Background="{DynamicResource SEPanelBgBrush}">
        <ListBox x:Name="LogList" Background="Transparent" ItemsSource="{Binding Log}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" FontSize="11.5" TextWrapping="Wrap"
                         FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </StackPanel>

    <!-- Progress bar (indeterminate until a tool reports a fraction) -->
    <ProgressBar Grid.Row="2" Margin="18,8,18,0" Height="4" Minimum="0" Maximum="1"
                 Value="{Binding Progress}" IsIndeterminate="{Binding IsProgressIndeterminate}"
                 IsVisible="{Binding IsRunning}" />

    <!-- Action bar -->
    <Grid Grid.Row="3" Margin="18,12" ColumnDefinitions="Auto,*,Auto,Auto">
      <TextBlock Grid.Column="0" Text="{Binding Loc[ToolRunning]}" VerticalAlignment="Center"
                 FontSize="11.5" Foreground="{DynamicResource SETextFaintBrush}"
                 IsVisible="{Binding IsRunning}" />

      <!-- Success banner (green check + text) shown once the tool finishes. -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                  IsVisible="{Binding IsCompleted}">
        <Border Width="16" Height="16" Background="#3FB950" CornerRadius="8">
          <Path Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                Stretch="Uniform" Stroke="White" StrokeThickness="1.6" StrokeLineCap="Round"
                Data="M3,8 L6.5,11 L13,4" />
        </Border>
        <TextBlock Text="{Binding Loc[ToolSucceeded]}" VerticalAlignment="Center" FontSize="12"
                   FontWeight="SemiBold" Foreground="#3FB950" />
      </StackPanel>

      <!-- Run controls: hidden once finished. -->
      <Button Grid.Column="2" Classes="Subtle" Content="{Binding Loc[Cancel]}"
              Command="{Binding CancelCommand}" Margin="0,0,8,0"
              IsVisible="{Binding !IsCompleted}" />
      <Button Grid.Column="3" Classes="Accent" Content="{Binding Title}"
              Command="{Binding ExecuteCommand}" IsEnabled="{Binding CanExecute}" IsDefault="True"
              IsVisible="{Binding !IsCompleted}" />

      <!-- Done: a single Finish button that closes the dialog. -->
      <Button Grid.Column="3" Classes="Accent" Content="{Binding Loc[ToolFinish]}"
              Command="{Binding CancelCommand}" IsDefault="True"
              IsVisible="{Binding IsCompleted}" />
    </Grid>
  </Grid>
</Window>
