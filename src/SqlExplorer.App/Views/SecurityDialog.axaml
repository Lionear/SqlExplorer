<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SqlExplorer.App.Views.SecurityDialog"
        Title="{Binding Title}"
        Width="600" SizeToContent="Height" MinWidth="520" MaxHeight="820"
        WindowStartupLocation="CenterOwner">
  <!-- The provider view owns its own action buttons (Cancel/Create), so this host has no action bar. -->
  <ScrollViewer>
    <ContentControl Content="{Binding View}" Margin="18,16" />
  </ScrollViewer>
</Window>
