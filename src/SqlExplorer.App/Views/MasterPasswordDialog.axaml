<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SqlExplorer.App.Views.MasterPasswordDialog"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="22" Spacing="10">
    <TextBlock x:Name="HeaderText" FontSize="15" FontWeight="SemiBold" />
    <TextBlock x:Name="DescText" FontSize="12" TextWrapping="Wrap"
               Foreground="{DynamicResource SETextSecondaryBrush}" />

    <StackPanel x:Name="CurrentPanel" Spacing="3" Margin="0,6,0,0">
      <TextBlock x:Name="CurrentLabel" />
      <TextBox x:Name="CurrentBox" PasswordChar="●" />
    </StackPanel>

    <StackPanel x:Name="NewPanel" Spacing="3">
      <TextBlock x:Name="NewLabel" />
      <TextBox x:Name="NewBox" PasswordChar="●" />
    </StackPanel>

    <StackPanel x:Name="ConfirmPanel" Spacing="3">
      <TextBlock x:Name="ConfirmLabel" />
      <TextBox x:Name="ConfirmBox" PasswordChar="●" />
    </StackPanel>

    <TextBlock x:Name="ErrorText" Foreground="#F0B4B4" FontSize="12" TextWrapping="Wrap" IsVisible="False" />

    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
      <Button x:Name="CancelButton" Grid.Column="1" Margin="0,0,8,0" Click="OnCancelClick" IsCancel="True" />
      <Button x:Name="ConfirmButton" Grid.Column="2" Classes="Accent" Click="OnConfirmClick" IsDefault="True" />
    </Grid>
  </StackPanel>
</Window>
