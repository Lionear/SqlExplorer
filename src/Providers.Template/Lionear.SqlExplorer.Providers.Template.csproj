<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Lionear.SqlExplorer.Providers.Template</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Shared contract only. Private=false keeps Sdk.dll OUT of the plugin folder so the host's copy
         is used across the ALC boundary (single type identity for IDbProvider / IPluginSettings). -->
    <ProjectReference Include="..\Sdk\Lionear.SqlExplorer.Sdk.csproj" Private="false" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="plugin.json" CopyToOutputDirectory="PreserveNewest" />
    <EmbeddedResource Include="icon.png" LogicalName="icon.png" Condition="Exists('icon.png')" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Lionear.SqlExplorer.Sdk.Connections" />
    <Using Include="Lionear.SqlExplorer.Sdk.Schema" />
    <Using Include="Lionear.SqlExplorer.Sdk.Query" />
    <Using Include="Lionear.SqlExplorer.Sdk.Ddl" />
    <Using Include="Lionear.SqlExplorer.Sdk.Branding" />
    <Using Include="Lionear.SqlExplorer.Sdk.Settings" />
  </ItemGroup>

</Project>
