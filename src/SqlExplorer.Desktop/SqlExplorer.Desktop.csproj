<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- WinExe = GUI subsystem on Windows (no console window allocated for this GUI app). On Linux/macOS
         WinExe is identical to Exe — no subsystem distinction — so the AppImage/DMG builds are unaffected. -->
    <OutputType>WinExe</OutputType>
    <RootNamespace>SqlExplorer.Desktop</RootNamespace>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <MacBundleName>SQL Explorer</MacBundleName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SqlExplorer.App\SqlExplorer.App.csproj" />
  </ItemGroup>

  <!-- Keep the macOS bundle metadata out of the plain build output; the CreateMacAppBundle
       target below copies them into the .app it assembles from the publish output. -->
  <ItemGroup>
    <None Update="Info.plist;app.icns" CopyToOutputDirectory="Never" />
  </ItemGroup>

  <!-- Attribution has to travel with the app, not just live in the repo: the bundled OSS licences
       (MIT/Apache-2.0/…) require the notices to be distributed alongside the binaries. Generated by
       tools/generate-third-party-notices.py; About links to the copy on GitHub (SE-127). -->
  <ItemGroup>
    <Content Include="..\..\THIRD-PARTY-NOTICES.md" Link="THIRD-PARTY-NOTICES.md"
             CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
    <Content Include="..\..\LICENSE" Link="LICENSE"
             CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" Version="12.0.5" />
  </ItemGroup>

  <!-- Each provider's self-contained output, tagged with the plugin-id folder it belongs in.
       Populated inside a target (not at project scope) because the wildcards must be evaluated
       after the providers have built, not during the initial project evaluation. -->
  <Target Name="CollectProviderPluginFiles">
    <ItemGroup>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\SqlExplorer.Providers.Postgres\bin\$(Configuration)\$(TargetFramework)\**\*">
        <PluginId>postgres</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\SqlExplorer.Providers.Sqlite\bin\$(Configuration)\$(TargetFramework)\**\*">
        <PluginId>sqlite</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\SqlExplorer.Providers.MySql\bin\$(Configuration)\$(TargetFramework)\**\*">
        <PluginId>mysql</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\SqlExplorer.Providers.MsSql\bin\$(Configuration)\$(TargetFramework)\**\*">
        <PluginId>sqlserver</PluginId>
      </ProviderPluginFile>
      <!-- Core admin tool plugin, staged unconditionally (Debug + Release) like the providers. -->
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\SqlExplorer.Tools.MsSqlAdmin\bin\$(Configuration)\$(TargetFramework)\**\*">
        <PluginId>mssql-admin</PluginId>
      </ProviderPluginFile>
      <!-- First-party MCP tools plugin, staged unconditionally like the providers/admin tool. -->
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\SqlExplorer.Mcp.Server\bin\$(Configuration)\$(TargetFramework)\**\*">
        <PluginId>sql-explorer-mcp</PluginId>
      </ProviderPluginFile>
      <!-- Debug-only, non-shipped plugins from the repo-root plugins/ folder (see App.csproj). Absent
           from Release/publish staging. Future dev-only tool plugins (plugins/Tools.*) go here too. -->
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Providers.Template\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>template</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Providers.DragonflyDb\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>dragonflydb</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Providers.Elasticsearch\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>elasticsearch</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Providers.MongoDb\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>mongodb</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Providers.Redis\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>redis</PluginId>
      </ProviderPluginFile>
      <!-- Cross-connection schema-diff tool (SE-99): store-only, Debug-staged for development but not
           bundled in Release — installed from the Plugin Store like the other plugins/ tools. -->
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Tools.SchemaDiff\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>schema-diff</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Tools.UniversalBackup\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>universal-backup</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Tools.MsSqlBacpac\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>mssql-bacpac</PluginId>
      </ProviderPluginFile>
      <ProviderPluginFile Include="$(MSBuildThisFileDirectory)..\..\plugins\Backends.Docker\bin\$(Configuration)\$(TargetFramework)\**\*"
                          Condition="'$(Configuration)' == 'Debug'">
        <PluginId>local-containers</PluginId>
      </ProviderPluginFile>
    </ItemGroup>
  </Target>

  <!-- Stage the providers into plugins/<id>/ beside the built executable, so the plugin loader
       discovers them exactly as it would third-party plugins. -->
  <Target Name="StageProviderPlugins" AfterTargets="Build" DependsOnTargets="CollectProviderPluginFiles">
    <Copy SourceFiles="@(ProviderPluginFile)"
          DestinationFiles="@(ProviderPluginFile->'$(TargetDir)plugins\%(PluginId)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- Same staging into the publish output. `dotnet publish` does not run the Build-time staging
       into $(PublishDir), so without this a published app (and the macOS bundle below) would ship
       with no database providers at all. -->
  <Target Name="StageProviderPluginsForPublish" AfterTargets="Publish" DependsOnTargets="CollectProviderPluginFiles">
    <Copy SourceFiles="@(ProviderPluginFile)"
          DestinationFiles="@(ProviderPluginFile->'$(PublishDir)plugins\%(PluginId)\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <!-- Assemble a real macOS .app bundle from the publish output. macOS reads the bold application-menu
       name and Dock title from Contents/Info.plist (CFBundleName); running the loose executable (or
       `dotnet run`) has no bundle, so it falls back to "Avalonia Application". Runs on macOS only,
       after Publish, so `dotnet publish -r osx-arm64` (or osx-x64) produces a launchable bundle.
       Depends on the publish staging so the copied tree already contains plugins/. -->
  <Target Name="CreateMacAppBundle" AfterTargets="Publish"
          DependsOnTargets="StageProviderPluginsForPublish"
          Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true'">
    <PropertyGroup>
      <MacBundleRoot>$(PublishDir)../$(MacBundleName).app</MacBundleRoot>
      <MacBundleContents>$(MacBundleRoot)/Contents</MacBundleContents>
      <MacBundleExe>$(MacBundleContents)/MacOS</MacBundleExe>
      <MacBundleResources>$(MacBundleContents)/Resources</MacBundleResources>
    </PropertyGroup>
    <RemoveDir Directories="$(MacBundleRoot)" />
    <MakeDir Directories="$(MacBundleExe);$(MacBundleResources)" />
    <ItemGroup>
      <MacPublishedFiles Include="$(PublishDir)**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(MacPublishedFiles)"
          DestinationFiles="@(MacPublishedFiles->'$(MacBundleExe)/%(RecursiveDir)%(Filename)%(Extension)')" />
    <Copy SourceFiles="Info.plist" DestinationFiles="$(MacBundleContents)/Info.plist" />
    <Copy SourceFiles="app.icns" DestinationFiles="$(MacBundleResources)/app.icns" />
    <Exec Command="chmod +x &quot;$(MacBundleExe)/$(AssemblyName)&quot;" />
    <Message Importance="high" Text="Created macOS app bundle: $(MacBundleRoot)" />
  </Target>

</Project>
