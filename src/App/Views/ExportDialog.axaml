<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Lionear.SqlExplorer.App.Views.ExportDialog"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="16" Spacing="10">
    <TextBlock x:Name="HeaderText" FontWeight="SemiBold" />
    <TextBlock x:Name="RowsText" FontSize="12" Foreground="{DynamicResource CatTextSecondaryBrush}" />

    <StackPanel Spacing="4" Margin="0,8,0,0">
      <RadioButton x:Name="CsvOption" GroupName="ExportFormat" IsChecked="True" Content="CSV" />
      <RadioButton x:Name="JsonOption" GroupName="ExportFormat" Content="JSON" />
      <RadioButton x:Name="SqlOption" GroupName="ExportFormat" Content="SQL (INSERT)" />
    </StackPanel>

    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
      <Button Grid.Column="1" x:Name="CancelButton" Classes="Subtle" Click="OnCancel" Margin="0,0,8,0" />
      <Button Grid.Column="2" x:Name="ExportButton" Classes="Accent" Click="OnExport" IsDefault="True" />
    </Grid>
  </StackPanel>
</Window>
