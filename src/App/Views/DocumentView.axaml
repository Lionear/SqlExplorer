<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ae="using:AvaloniaEdit"
             xmlns:conv="using:Avalonia.Data.Converters"
             x:Class="Lionear.SqlExplorer.App.Views.DocumentView">
  <UserControl.Styles>
    <!-- Flat tabs matching the document-tab strip (Theme.axaml TabItem): plain text, no button
         chrome, just an accent underline on the selected one — this is a sibling tab strip
         (one result set of one Run), not a button toolbar, so it should read the same way. -->
    <Style Selector="Button.ResultTab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource CatTextSecondaryBrush}" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="Button.ResultTab:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource CatHoverBgBrush}" />
    </Style>
    <Style Selector="Button.ResultTab.Accent">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource CatAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
    </Style>
  </UserControl.Styles>
  <Grid x:Name="RootGrid" RowDefinitions="Auto,2*,Auto,Auto,Auto,3*,Auto,Auto">

    <!-- Row 0: mode-specific toolbar. Query = connection/database switcher + Run/Format; Browse = paging + filter. -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8"
                IsVisible="{Binding IsQueryMode}">
      <Button Classes="Accent" Content="{Binding Loc[Run]}" Command="{Binding RunCommand}"
              IsVisible="{Binding !IsRunning}" />
      <!-- Swaps in while a query runs: cancels the in-flight command via its CancellationToken. -->
      <Button Classes="Accent" Content="{Binding Loc[Stop]}" Command="{Binding StopCommand}"
              IsVisible="{Binding IsRunning}" />
      <Button Content="{Binding Loc[RunAtCursor]}" Command="{Binding RunAtCursorCommand}" />
      <Button Content="{Binding Loc[Explain]}" Command="{Binding ExplainCommand}" />
      <Button Content="{Binding Loc[Format]}" Command="{Binding FormatCommand}" />
      <!-- Connection/database switcher (DBeaver-style): pick which saved connection — and which
           database on it — this query tab runs against. Database combo hides itself when the engine
           has no database layer (SQLite: HasDatabasePicker stays false). -->
      <ComboBox MinWidth="160" ItemsSource="{Binding AvailableConnections}"
                SelectedItem="{Binding Connection}">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <ComboBox MinWidth="140" ItemsSource="{Binding AvailableDatabases}"
                SelectedItem="{Binding SelectedDatabase}"
                IsVisible="{Binding HasDatabasePicker}" />
    </StackPanel>

    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,8" IsVisible="{Binding IsBrowseMode}">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
        <Button Grid.Column="0" Margin="0,0,6,0"
                Content="{Binding Loc[PrevPage]}" Command="{Binding PrevPageCommand}" />
        <Button Grid.Column="1" Margin="0,0,10,0"
                Content="{Binding Loc[NextPage]}" Command="{Binding NextPageCommand}" />
        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0"
                   FontSize="12" Foreground="{DynamicResource CatTextSecondaryBrush}"
                   Text="{Binding RowRange}" />
        <TextBox Grid.Column="3" MinWidth="160"
                 Text="{Binding FilterText}"
                 PlaceholderText="{Binding Loc[Filter]}" />
        <Button Grid.Column="4" Margin="8,0,0,0"
                Content="{Binding Loc[Apply]}" Command="{Binding ApplyFilterCommand}" IsDefault="True" />
      </Grid>

      <!-- Per-column inline filter: one small box per browse-grid column, combined with the free-text
           WHERE box above (AND) on the same Apply command — no separate auto-apply logic needed. -->
      <ItemsControl ItemsSource="{Binding ColumnFilters}"
                    IsVisible="{Binding ColumnFilters.Count}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBox Width="110" Margin="0,0,6,4" Text="{Binding Value}" PlaceholderText="{Binding ColumnName}"
                     KeyDown="OnColumnFilterKeyDown" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <!-- Row 1: SQL editor (query mode only; the row is collapsed for browse in code-behind). -->
    <Border Grid.Row="1" IsVisible="{Binding IsQueryMode}"
            Background="{DynamicResource CatWindowBgBrush}"
            BorderBrush="{DynamicResource CatHairlineBrush}" BorderThickness="1"
            CornerRadius="{StaticResource CatControlRadius}" ClipToBounds="True">
      <ae:TextEditor x:Name="SqlEditor"
                     ShowLineNumbers="True"
                     WordWrap="{Binding EditorWordWrap}"
                     Padding="4"
                     FontFamily="Cascadia Code,Consolas,Menlo,monospace" />
    </Border>

    <!-- Row 2 is intentionally empty (Auto → 0 height): execution outcomes now surface only in the
         host's Output panel, not inline under the editor. -->

    <!-- Row 3: edit toolbar + pending-changes bar (shared by both modes). -->
    <Grid Grid.Row="3" Margin="0,0,0,8"
          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
          IsVisible="{Binding Editable, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
      <Button Grid.Column="0" Margin="0,0,8,0"
              Content="{Binding Loc[AddRow]}" Command="{Binding AddRowCommand}" />
      <Button Grid.Column="1" Margin="0,0,8,0"
              Content="{Binding Loc[DeleteRow]}" Command="{Binding DeleteRowCommand}" />
      <Button Grid.Column="2" Margin="0,0,8,0" Classes="Accent"
              Content="{Binding Loc[Save]}" Command="{Binding SaveCommand}" />
      <Button Grid.Column="3" Classes="Subtle" Margin="0,0,8,0"
              Content="{Binding Loc[Discard]}" Command="{Binding DiscardCommand}" />
      <Button Grid.Column="4" Classes="Subtle" x:Name="ExportButton" Click="OnExportClick"
              Content="{Binding Loc[Export]}" />
      <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="12,0,0,0"
                 Foreground="{DynamicResource CatTextSecondaryBrush}"
                 Text="{Binding PendingSummary}" />
      <TextBlock Grid.Column="6" VerticalAlignment="Center"
                 Foreground="{DynamicResource CatTextFaintBrush}"
                 Text="{Binding ReadOnlyReason}"
                 IsVisible="{Binding ReadOnlyReason, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
    </Grid>

    <!-- Row 4: result-set tab strip — only shown for a multi-statement/multi-resultset run or Explain. -->
    <ItemsControl Grid.Row="4" Margin="0,0,0,6" ItemsSource="{Binding ResultSets}"
                  IsVisible="{Binding HasMultipleResultSets}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" Spacing="4" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Button Classes="ResultTab" Classes.Accent="{Binding IsSelected}" Content="{Binding Label}"
                  Command="{Binding $parent[ItemsControl].DataContext.SelectResultSetCommand}"
                  CommandParameter="{Binding}" />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Row 5: editable result grid, framed. Columns are built per result set in code-behind. -->
    <Border Grid.Row="5"
            BorderBrush="{DynamicResource CatHairlineBrush}" BorderThickness="1"
            CornerRadius="{StaticResource CatControlRadius}" ClipToBounds="True">
      <DataGrid x:Name="ResultsGrid"
                AutoGenerateColumns="False"
                IsReadOnly="{Binding !IsResultEditable}"
                SelectedItem="{Binding SelectedRow}"
                SelectionMode="Extended"
                CanUserResizeColumns="True">
        <DataGrid.ContextMenu>
          <!-- Copies the current selection, or the whole result set if nothing is selected — same
               source/fallback as the "Export…" button, just to the clipboard instead of a file. -->
          <ContextMenu>
            <MenuItem Header="{Binding Loc[SetNull]}" Click="OnSetNullClick"
                      IsVisible="{Binding IsResultEditable}" />
            <MenuItem Header="{Binding Loc[CopyCell]}" Click="OnCopyCellClick" />
            <MenuItem Header="{Binding Loc[Copy]}" Click="OnCopyClick" />
            <MenuItem Header="{Binding Loc[CopyWithHeaders]}" Click="OnCopyWithHeadersClick" />
            <Separator />
            <MenuItem Header="{Binding Loc[CopyAsCsv]}" Click="OnCopyAsCsvClick" />
            <MenuItem Header="{Binding Loc[CopyAsMarkdown]}" Click="OnCopyAsMarkdownClick" />
            <MenuItem Header="{Binding Loc[CopyAsInsert]}" Click="OnCopyAsInsertClick" />
          </ContextMenu>
        </DataGrid.ContextMenu>
      </DataGrid>
    </Border>

    <!-- Row 6: selection aggregation strip (count + sum/avg/min/max for a numeric column). -->
    <Border Grid.Row="6" Margin="0,4,0,0" Padding="8,3"
            Background="{DynamicResource CatToolbarBgBrush}"
            BorderBrush="{DynamicResource CatHairlineBrush}" BorderThickness="1"
            CornerRadius="{StaticResource CatControlRadius}"
            IsVisible="{Binding AggregationSummary, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding AggregationSummary}" FontSize="12"
                 Foreground="{DynamicResource CatTextSecondaryBrush}" />
    </Border>

    <!-- Row 7: cell-value viewer — appears on cell click; full value, JSON pretty-printed when parseable. -->
    <Border Grid.Row="7" Margin="0,8,0,0" MaxHeight="200"
            IsVisible="{Binding IsCellViewerVisible}"
            BorderBrush="{DynamicResource CatHairlineBrush}" BorderThickness="1"
            CornerRadius="{StaticResource CatControlRadius}" ClipToBounds="True">
      <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,4"
              Background="{DynamicResource CatToolbarBgBrush}">
          <TextBlock Grid.Column="0" Text="{Binding SelectedCellColumn}" VerticalAlignment="Center"
                     FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource CatTextSecondaryBrush}" />
          <Button Grid.Column="1" Classes="Subtle" Content="×" Padding="6,0" FontSize="15"
                  Command="{Binding HideCellViewerCommand}" />
        </Grid>
        <TextBox Grid.Row="1" Text="{Binding SelectedCellValue}"
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                 BorderThickness="0" Padding="6"
                 FontFamily="Cascadia Code,Consolas,Menlo,monospace" FontSize="12"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
