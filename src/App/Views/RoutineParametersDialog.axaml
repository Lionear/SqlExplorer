<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Lionear.SqlExplorer.App.Views.RoutineParametersDialog"
        Title="{Binding Title}"
        Width="460" Height="420" MinWidth="380" MinHeight="260"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <!-- One row per parameter: IN rows are editable, OUT/return rows are disabled with an "(output)" hint. -->
    <DataTemplate x:Key="ParameterTemplate">
      <StackPanel Spacing="2" Margin="0,4,0,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="{Binding Name}" Foreground="{DynamicResource CatTextSecondaryBrush}" FontSize="11.5" />
          <TextBlock Text="{Binding Type}" Foreground="{DynamicResource CatTextFaintBrush}" FontSize="11.5" />
          <TextBlock Text="{Binding $parent[Window].DataContext.Loc[ParameterOutput]}"
                     Foreground="{DynamicResource CatTextFaintBrush}" FontSize="11.5"
                     IsVisible="{Binding IsOutput}" />
        </StackPanel>
        <TextBox Text="{Binding Value}" IsEnabled="{Binding IsInput}" />
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Grid RowDefinitions="Auto,*,Auto">

    <TextBlock Grid.Row="0" Margin="18,16,18,0" TextWrapping="Wrap" FontSize="11.5"
               Foreground="{DynamicResource CatTextSecondaryBrush}"
               Text="{Binding Loc[RoutineExecuteHint]}" />

    <ScrollViewer Grid.Row="1" Margin="0,4,0,0">
      <ItemsControl ItemsSource="{Binding Parameters}" ItemTemplate="{StaticResource ParameterTemplate}"
                    Margin="18,4" />
    </ScrollViewer>

    <!-- Action bar -->
    <Grid Grid.Row="2" Margin="18,12" ColumnDefinitions="*,Auto,Auto">
      <Button Grid.Column="1" Classes="Subtle" Content="{Binding Loc[Cancel]}"
              Command="{Binding CancelCommand}" Margin="0,0,8,0" />
      <Button Grid.Column="2" Classes="Accent" Content="{Binding Loc[OpenInEditor]}"
              Command="{Binding ConfirmCommand}" IsDefault="True" />
    </Grid>
  </Grid>
</Window>
