<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Lionear.SqlExplorer.App.Views.SaveReviewDialog"
        Width="560" Height="440"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16" RowDefinitions="Auto,*,Auto">
    <TextBlock Grid.Row="0" x:Name="HeaderText" FontWeight="SemiBold" />

    <!-- The generated, parameterised SQL, read-only for review before it runs. -->
    <TextBox Grid.Row="1" x:Name="SqlText"
             Margin="0,8"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             FontFamily="Cascadia Code,Consolas,Menlo,monospace"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Auto" />

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button x:Name="CancelButton" Classes="Subtle" Click="OnCancel" />
      <Button x:Name="ApplyButton" Classes="Accent" Click="OnApply" IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
