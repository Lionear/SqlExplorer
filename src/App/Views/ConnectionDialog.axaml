<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:Lionear.SqlExplorer.App.Converters"
        x:Class="Lionear.SqlExplorer.App.Views.ConnectionDialog"
        Title="{Binding DialogTitle}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <!-- One row per ConnectionField, shared between the basic list and the Advanced expander.
         Exactly one input control shows per field, keyed off the field type. -->
    <DataTemplate x:Key="FieldTemplate">
      <StackPanel Spacing="2" Margin="0,4,0,0">
        <TextBlock Text="{Binding Label}" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
                   Text="{Binding Value}"
                   PlaceholderText="{Binding Watermark}"
                   PasswordChar="{Binding PasswordChar}"
                   IsVisible="{Binding IsText}" />
          <CheckBox Grid.Column="0"
                    IsChecked="{Binding BoolValue}"
                    IsVisible="{Binding IsBool}" />
          <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Choices}"
                    SelectedItem="{Binding Value}"
                    IsVisible="{Binding IsChoice}" />
          <Button Grid.Column="1" Margin="6,0,0,0"
                  Content="{Binding $parent[Window].DataContext.Loc[Browse]}"
                  IsVisible="{Binding IsFile}"
                  Click="OnBrowseClick" />
        </Grid>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>
  <StackPanel Margin="16" Spacing="10">

    <TextBlock Text="{Binding Loc[ConnectionName]}" />
    <TextBox Text="{Binding Name}" />

    <TextBlock Text="{Binding Loc[Provider]}" />
    <ComboBox ItemsSource="{Binding AvailableProviders}"
              SelectedItem="{Binding SelectedProvider}"
              HorizontalAlignment="Stretch" />

    <!-- Provider-driven fields: basics always visible, one control per declared ConnectionField. -->
    <ItemsControl ItemsSource="{Binding BasicFields}" ItemTemplate="{StaticResource FieldTemplate}" />

    <!-- Advanced/driver-specific settings tuck away until asked for; only shown if the provider has any. -->
    <Expander Header="{Binding Loc[AdvancedSettings]}" IsVisible="{Binding HasAdvancedFields}" Margin="0,4,0,0">
      <ItemsControl ItemsSource="{Binding AdvancedFields}" ItemTemplate="{StaticResource FieldTemplate}" />
    </Expander>

    <!-- Colour flag (prod = red) + safe read-only mode. -->
    <TextBlock Text="{Binding Loc[ConnectionColor]}" Margin="0,4,0,0" />
    <ItemsControl ItemsSource="{Binding ColorOptions}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" Spacing="6" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Button Padding="0" Background="Transparent" BorderThickness="0"
                  Command="{Binding $parent[ItemsControl].DataContext.SelectColorCommand}"
                  CommandParameter="{Binding}">
            <Panel Width="24" Height="24">
              <Ellipse Width="20" Height="20"
                       Fill="{Binding Value, Converter={x:Static conv:HexBrushConverter.Instance}}"
                       Stroke="{DynamicResource CatHairlineBrush}" StrokeThickness="1" />
              <Ellipse Width="24" Height="24" StrokeThickness="2"
                       Stroke="{DynamicResource CatAccentBrush}"
                       IsVisible="{Binding IsSelected}" />
            </Panel>
          </Button>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <CheckBox IsChecked="{Binding ReadOnly}" Content="{Binding Loc[ReadOnlyMode]}" Margin="0,4,0,0" />

    <TextBlock Text="{Binding TestResult}" Foreground="{DynamicResource CatTextFaintBrush}" Margin="0,4,0,0" />

    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,8,0,0">
      <Button Grid.Column="0" Content="{Binding Loc[Test]}" Command="{Binding TestCommand}" />
      <Button Grid.Column="2" Classes="Subtle" Content="{Binding Loc[Cancel]}" Click="OnCancel" Margin="0,0,8,0" />
      <Button Grid.Column="3" Classes="Accent" Content="{Binding Loc[Save]}" Click="OnSave"
              IsEnabled="{Binding CanSave}" IsDefault="True" />
    </Grid>
  </StackPanel>
</Window>
