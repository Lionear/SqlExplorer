<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Lionear.SqlExplorer.App.Views.ConfirmDialog"
        Width="420" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="18" Spacing="16">
    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
    <Grid ColumnDefinitions="*,Auto,Auto">
      <Button Grid.Column="1" Classes="Subtle" Content="{Binding NoText}" Click="OnNo" Margin="0,0,8,0" />
      <Button Grid.Column="2" Classes="Accent" Content="{Binding YesText}" Click="OnYes" IsDefault="True" />
    </Grid>
  </StackPanel>
</Window>
