<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Lionear theme: flat, dense, IDE-grade (DataGrip-ish). Tokens live in per-variant
       ThemeDictionaries and are consumed via DynamicResource, so the app follows the OS
       light/dark setting and a value swap re-themes everything. Geometry/typography tokens
       are variant-invariant (defined once). -->
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>

        <!-- Dark -->
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="CatWindowBgBrush" Color="#1E1F22" />
          <SolidColorBrush x:Key="CatPanelBgBrush" Color="#2B2D30" />
          <SolidColorBrush x:Key="CatSecondaryBgBrush" Color="#26282B" />
          <SolidColorBrush x:Key="CatToolbarBgBrush" Color="#2B2D30" />
          <SolidColorBrush x:Key="CatHairlineBrush" Color="#393B40" />
          <SolidColorBrush x:Key="CatHoverBgBrush" Color="#2E3338" />
          <SolidColorBrush x:Key="CatSelectionBgBrush" Color="#2E436E" />

          <SolidColorBrush x:Key="CatTextPrimaryBrush" Color="#DFE1E5" />
          <SolidColorBrush x:Key="CatTextSecondaryBrush" Color="#9DA0A8" />
          <SolidColorBrush x:Key="CatTextFaintBrush" Color="#6F737A" />

          <SolidColorBrush x:Key="CatAccentBrush" Color="#3574F0" />
          <SolidColorBrush x:Key="CatAccentHoverBrush" Color="#4A83F2" />
          <SolidColorBrush x:Key="CatAccentPressedBrush" Color="#2C63D6" />
          <SolidColorBrush x:Key="CatAccentFgBrush" Color="#FFFFFF" />

          <SolidColorBrush x:Key="CatStatusConnectedBrush" Color="#5AA576" />
          <SolidColorBrush x:Key="CatStatusErrorBrush" Color="#D64545" />
          <SolidColorBrush x:Key="CatStatusBusyBrush" Color="#3574F0" />
          <SolidColorBrush x:Key="CatStatusWaitingBrush" Color="#E0A33E" />
        </ResourceDictionary>

        <!-- Light -->
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="CatWindowBgBrush" Color="#FFFFFF" />
          <SolidColorBrush x:Key="CatPanelBgBrush" Color="#F7F8FA" />
          <SolidColorBrush x:Key="CatSecondaryBgBrush" Color="#EEF0F3" />
          <SolidColorBrush x:Key="CatToolbarBgBrush" Color="#F0F1F3" />
          <SolidColorBrush x:Key="CatHairlineBrush" Color="#D9DCE1" />
          <SolidColorBrush x:Key="CatHoverBgBrush" Color="#EAEDF1" />
          <SolidColorBrush x:Key="CatSelectionBgBrush" Color="#D4E2FC" />

          <SolidColorBrush x:Key="CatTextPrimaryBrush" Color="#1B1D21" />
          <SolidColorBrush x:Key="CatTextSecondaryBrush" Color="#5B616B" />
          <SolidColorBrush x:Key="CatTextFaintBrush" Color="#8A909A" />

          <SolidColorBrush x:Key="CatAccentBrush" Color="#2F6FEB" />
          <SolidColorBrush x:Key="CatAccentHoverBrush" Color="#2560D6" />
          <SolidColorBrush x:Key="CatAccentPressedBrush" Color="#1F53BC" />
          <SolidColorBrush x:Key="CatAccentFgBrush" Color="#FFFFFF" />

          <SolidColorBrush x:Key="CatStatusConnectedBrush" Color="#2E8B57" />
          <SolidColorBrush x:Key="CatStatusErrorBrush" Color="#C4362F" />
          <SolidColorBrush x:Key="CatStatusBusyBrush" Color="#2F6FEB" />
          <SolidColorBrush x:Key="CatStatusWaitingBrush" Color="#B9791F" />
        </ResourceDictionary>

      </ResourceDictionary.ThemeDictionaries>

      <!-- Variant-invariant tokens -->
      <CornerRadius x:Key="CatControlRadius">6</CornerRadius>
      <CornerRadius x:Key="CatPanelRadius">10</CornerRadius>
      <Thickness x:Key="CatHairlineThickness">1</Thickness>
      <FontFamily x:Key="CatMonoFont">Cascadia Code, Consolas, Menlo, monospace</FontFamily>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Window chrome -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource CatWindowBgBrush}" />
  </Style>

  <!-- Base text (:is so SelectableTextBlock inherits too) -->
  <Style Selector=":is(TextBlock)">
    <Setter Property="Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
  </Style>

  <!-- Buttons: flat, hairline, rounded. Accent reserved for primary actions via the class. -->
  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource CatPanelBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatHairlineBrush}" />
    <Setter Property="BorderThickness" Value="{StaticResource CatHairlineThickness}" />
    <Setter Property="CornerRadius" Value="{StaticResource CatControlRadius}" />
    <Setter Property="Padding" Value="11,5" />
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatHoverBgBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatHairlineBrush}" />
  </Style>
  <Style Selector="Button:disabled /template/ ContentPresenter">
    <Setter Property="Opacity" Value="0.45" />
  </Style>

  <Style Selector="Button.Accent">
    <Setter Property="Background" Value="{DynamicResource CatAccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource CatAccentFgBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatAccentBrush}" />
  </Style>
  <Style Selector="Button.Accent:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatAccentHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatAccentHoverBrush}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource CatAccentFgBrush}" />
  </Style>
  <Style Selector="Button.Accent:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatAccentPressedBrush}" />
  </Style>

  <!-- Subtle button: chromeless, text-only (toggles, footer actions) -->
  <Style Selector="Button.Subtle">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource CatTextSecondaryBrush}" />
    <Setter Property="Padding" Value="8,4" />
  </Style>
  <Style Selector="Button.Subtle:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatHoverBgBrush}" />
    <Setter Property="TextBlock.Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource CatPanelBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatHairlineBrush}" />
    <Setter Property="BorderThickness" Value="{StaticResource CatHairlineThickness}" />
    <Setter Property="CornerRadius" Value="{StaticResource CatControlRadius}" />
    <Setter Property="Padding" Value="8,4" />
  </Style>
  <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatHoverBgBrush}" />
  </Style>
  <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatSelectionBgBrush}" />
  </Style>

  <!-- TextBox: input surface, accent focus ring instead of Fluent blue -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource CatSecondaryBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource CatTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatHairlineBrush}" />
    <Setter Property="BorderThickness" Value="{StaticResource CatHairlineThickness}" />
    <Setter Property="CornerRadius" Value="{StaticResource CatControlRadius}" />
    <Setter Property="Padding" Value="8,6" />
  </Style>
  <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
    <Setter Property="Foreground" Value="{DynamicResource CatTextFaintBrush}" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource CatAccentBrush}" />
  </Style>

  <!-- ListBox: flat; selected row gets a quiet panel-bg fill, not Fluent blue -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="6,5" />
    <Setter Property="CornerRadius" Value="{StaticResource CatControlRadius}" />
  </Style>
  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatHoverBgBrush}" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource CatSelectionBgBrush}" />
  </Style>

  <!-- TreeView: dense IDE rows, accent-tinted selection, quiet hover -->
  <Style Selector="TreeView">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="TreeViewItem">
    <Setter Property="Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="4,1" />
  </Style>
  <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource CatHoverBgBrush}" />
  </Style>
  <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource CatSelectionBgBrush}" />
  </Style>
  <Style Selector="TreeViewItem:selected:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource CatSelectionBgBrush}" />
  </Style>

  <!-- Tabs: flat editor tabs with an accent underline on the active tab (DataGrip-style) -->
  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="TabItem">
    <Setter Property="Foreground" Value="{DynamicResource CatTextSecondaryBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="12,4" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatHairlineBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>
  <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource CatHoverBgBrush}" />
  </Style>
  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource CatTextPrimaryBrush}" />
  </Style>
  <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource CatWindowBgBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatAccentBrush}" />
    <Setter Property="BorderThickness" Value="0,2,0,0" />
  </Style>

  <!-- DataGrid: horizontal-only rules, compact rows, themed header with a bottom hairline -->
  <Style Selector="DataGrid">
    <Setter Property="Background" Value="{DynamicResource CatWindowBgBrush}" />
    <Setter Property="RowBackground" Value="Transparent" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource CatHairlineBrush}" />
    <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource CatHairlineBrush}" />
    <Setter Property="RowHeight" Value="26" />
  </Style>
  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource CatToolbarBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource CatTextSecondaryBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="BorderBrush" Value="{DynamicResource CatHairlineBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,1" />
    <Setter Property="Padding" Value="8,5" />
  </Style>

</Styles>
