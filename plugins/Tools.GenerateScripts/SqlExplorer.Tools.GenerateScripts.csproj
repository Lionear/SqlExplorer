<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>SqlExplorer.Tools.GenerateScripts</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Contract only: the tool reads the schema through the host's IDbProvider and hands the script to a
         query tab or a file — no driver dependency, no DDL of its own. Route A (declared fields), so no
         Avalonia reference. Private=false keeps Sdk.dll out of the plugin folder so the host's copy is used
         across the ALC boundary. -->
    <ProjectReference Include="..\..\src\SqlExplorer.Sdk\SqlExplorer.Sdk.csproj" Private="false" />
  </ItemGroup>

  <ItemGroup>
    <!-- Reading a schema and rendering DDL for a dialect is shared with Schema Diff and Copy Table,
         source-linked rather than packaged. See plugins/Shared.Schema/README.md. -->
    <Compile Include="..\Shared.Schema\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="plugin.json" CopyToOutputDirectory="PreserveNewest" />
    <EmbeddedResource Include="Lang\strings.json" LogicalName="Lang/strings.json" WithCulture="false" />
    <EmbeddedResource Include="Lang\strings.nl.json" LogicalName="Lang/strings.nl.json" WithCulture="false" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="SqlExplorer.Sdk" />
    <Using Include="SqlExplorer.Sdk.Connections" />
    <Using Include="SqlExplorer.Sdk.Schema" />
    <Using Include="SqlExplorer.Sdk.Query" />
    <Using Include="SqlExplorer.Sdk.Localization" />
    <Using Include="SqlExplorer.Sdk.Tools" />
    <Using Include="SqlExplorer.Plugins.Schema" />
  </ItemGroup>

</Project>
